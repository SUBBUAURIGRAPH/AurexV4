+/**
+ * biocarbon.ts — API routes for VCC tokenization
+ *
+ * Mount at: /api/biocarbon
+ * All routes require auth + org scope.
+ * Lifecycle-mutating routes require ORG_ADMIN or SUPER_ADMIN.
+ */
+
+import { Router, type IRouter } from 'express';
+import { z } from 'zod';
+import { requireAuth } from '../middleware/auth.js';
+import { requireOrgScope } from '../middleware/org-scope.js';
+import { requireOrgRole } from '../middleware/org-role.js';
+import * as bc from '../services/biocarbon.service.js';
+
+export const biocarbonRouter: IRouter = Router();
+
+biocarbonRouter.use(requireAuth, requireOrgScope);
+
+// ─── Partner ────────────────────────────────────────────────────────────────
+
+/** GET /partner — get this org's BioCarbon partner record */
+biocarbonRouter.get('/partner', async (req, res, next) => {
+  try {
+    const partner = await bc.getPartner(req.orgId!);
+    res.json({ data: partner ?? null });
+  } catch (err) {
+    next(err);
+  }
+});
+
+const partnerUpsertSchema = z.object({
+  blockchainPlatform: z.string().min(1).max(100),
+  smartContractUrl: z.string().url().optional(),
+  auditReportUrl: z.string().url().optional(),
+});
+
+/** POST /partner — register or update partner details */
+biocarbonRouter.post(
+  '/partner',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const data = partnerUpsertSchema.parse(req.body);
+      const partner = await bc.upsertPartner(req.orgId!, data);
+      res.status(201).json({ data: partner });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+const partnerStatusSchema = z.object({
+  status: z.enum(['AUTHORIZED', 'SUSPENDED', 'REVOKED']),
+  notes: z.string().max(2000).optional(),
+});
+
+/** PATCH /partner/status — SUPER_ADMIN only: set authorization status */
+biocarbonRouter.patch(
+  '/partner/status',
+  requireOrgRole('SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const { status, notes } = partnerStatusSchema.parse(req.body);
+      const partner = await bc.setPartnerStatus(req.orgId!, status, notes);
+      res.json({ data: partner });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+// ─── Token listing & lookup ─────────────────────────────────────────────────
+
+const listQuerySchema = z.object({
+  status: z.string().optional(),
+  vintage: z.coerce.number().int().optional(),
+  page: z.coerce.number().int().min(1).default(1),
+  limit: z.coerce.number().int().min(1).max(100).default(20),
+});
+
+/** GET /tokens — paginated list of org's VCC tokens */
+biocarbonRouter.get('/tokens', async (req, res, next) => {
+  try {
+    const filters = listQuerySchema.parse(req.query);
+    const result = await bc.listOrgTokens(req.orgId!, filters as never);
+    res.json(result);
+  } catch (err) {
+    next(err);
+  }
+});
+
+/** GET /tokens/:id — token detail + full history */
+biocarbonRouter.get('/tokens/:id', async (req, res, next) => {
+  try {
+    const token = await bc.getTokenWithHistory(req.params.id!, req.orgId!);
+    res.json({ data: token });
+  } catch (err) {
+    next(err);
+  }
+});
+
+/** GET /tokens/by-serial/:serialId — lookup by BioCarbon serial */
+biocarbonRouter.get('/tokens/by-serial/:serialId', async (req, res, next) => {
+  try {
+    const token = await bc.getTokenBySerial(
+      decodeURIComponent(req.params.serialId!),
+      req.orgId!,
+    );
+    res.json({ data: token });
+  } catch (err) {
+    next(err);
+  }
+});
+
+// ─── Lifecycle mutations ────────────────────────────────────────────────────
+
+const lockRequestSchema = z.object({
+  biocarbonSerialId: z.string().min(1).max(200),
+  vintage: z.number().int().min(2000).max(2100),
+  projectId: z.string().min(1).max(100),
+  projectTitle: z.string().min(1).max(500),
+  projectCountry: z.string().length(2),
+  methodology: z.string().max(200).optional(),
+  registryUrl: z.string().url().optional(),
+  tokenStandard: z.enum(['NFT', 'SFT']).optional(),
+});
+
+/** POST /tokens — Step 6: request VCC lock and create token record */
+biocarbonRouter.post(
+  '/tokens',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const input = lockRequestSchema.parse(req.body);
+      const token = await bc.requestVccLock(req.orgId!, input);
+      res.status(201).json({ data: token });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+/** POST /tokens/:id/confirm-lock — Step 7: confirm registry locked the VCC */
+biocarbonRouter.post(
+  '/tokens/:id/confirm-lock',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const token = await bc.confirmVccLocked(req.params.id!, req.orgId!);
+      res.json({ data: token });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+const mintSchema = z.object({
+  tokenAddress: z.string().min(1).max(200),
+  metadataHash: z.string().min(1).max(255),
+  txHash: z.string().min(1).max(255),
+  blockHeight: z.number().int().optional(),
+});
+
+/** POST /tokens/:id/mint — Step 8: record on-chain mint */
+biocarbonRouter.post(
+  '/tokens/:id/mint',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const input = mintSchema.parse(req.body);
+      const token = await bc.mintToken(req.params.id!, req.orgId!, {
+        ...input,
+        blockHeight: input.blockHeight ? BigInt(input.blockHeight) : undefined,
+      });
+      res.json({ data: token });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+/** POST /tokens/:id/list — Step 9: make token available on marketplace */
+biocarbonRouter.post(
+  '/tokens/:id/list',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const token = await bc.listToken(req.params.id!, req.orgId!);
+      res.json({ data: token });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+const retirementInitSchema = z.object({
+  beneficiaryName: z.string().min(1).max(255),
+  beneficiaryType: z.enum(['INDIVIDUAL', 'COMPANY', 'GOVERNMENT', 'NGO']),
+  retirementPurpose: z.string().min(1).max(500),
+});
+
+/** POST /tokens/:id/initiate-retirement — Step 13: identify beneficiary */
+biocarbonRouter.post(
+  '/tokens/:id/initiate-retirement',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const input = retirementInitSchema.parse(req.body);
+      const token = await bc.initiateRetirement(req.params.id!, req.orgId!, input);
+      res.json({ data: token });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+const burnSchema = z.object({
+  txHash: z.string().min(1).max(255),
+  blockHeight: z.number().int().optional(),
+});
+
+/** POST /tokens/:id/burn — Step 14-15: burn token and retire VCC in registry */
+biocarbonRouter.post(
+  '/tokens/:id/burn',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const input = burnSchema.parse(req.body);
+      const result = await bc.burnAndRetire(req.params.id!, req.orgId!, {
+        txHash: input.txHash,
+        blockHeight: input.blockHeight ? BigInt(input.blockHeight) : undefined,
+      });
+      res.json({ data: result });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
+
+const delistSchema = z.object({
+  txHash: z.string().min(1).max(255),
+  reason: z.string().min(1).max(500),
+});
+
+/** POST /tokens/:id/delist — Step 11a-11b: two-way bridge, unlock VCC */
+biocarbonRouter.post(
+  '/tokens/:id/delist',
+  requireOrgRole('ORG_ADMIN', 'SUPER_ADMIN'),
+  async (req, res, next) => {
+    try {
+      const input = delistSchema.parse(req.body);
+      const token = await bc.delistAndUnlock(req.params.id!, req.orgId!, input);
+      res.json({ data: token });
+    } catch (err) {
+      next(err);
+    }
+  },
+);
