+// ─── BioCarbon VCC Tokenization (WBS Phase 1-6) ───────────────────────────
+
+/// BioCarbon Third-Party authorization record for the org
+model BiocarbonPartner {
+  id                  String                @id @default(uuid()) @db.Uuid
+  orgId               String                @map("org_id") @db.Uuid
+  status              BiocarbonPartnerStatus @default(PENDING)
+  blockchainPlatform  String                @map("blockchain_platform") @db.VarChar(100)
+  smartContractUrl    String?               @map("smart_contract_url") @db.VarChar(500)
+  auditReportUrl      String?               @map("audit_report_url") @db.VarChar(500)
