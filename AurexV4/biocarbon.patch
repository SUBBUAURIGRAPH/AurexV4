+  vccTokens           VccToken[]
+
+  @@unique([orgId])
+  @@index([status])
+  @@map("biocarbon_partners")
+}
+
+enum BiocarbonPartnerStatus {
+  PENDING       @map("pending")
+  AUTHORIZED    @map("authorized")
+  SUSPENDED     @map("suspended")
+  REVOKED       @map("revoked")
+}
+
+/// A single Verified Carbon Credit locked and minted as a blockchain token.
+/// One VCC = one token (1 tonne CO2eq). No pooling, no fractionalization.
+model VccToken {
+  id                  String        @id @default(uuid()) @db.Uuid
+  partnerId           String        @map("partner_id") @db.Uuid
+  orgId               String        @map("org_id") @db.Uuid
+
+  /// BioCarbon serial ID — e.g. BCR-CO-123-1-001-2-2001-2012-00001-12345
+  biocarbonSerialId   String        @unique @map("biocarbon_serial_id") @db.VarChar(200)
+  vintage             Int
+  projectId           String        @map("project_id") @db.VarChar(100)
+  projectTitle        String        @map("project_title") @db.VarChar(500)
+  projectCountry      String        @map("project_country") @db.VarChar(2)
+  methodology         String?       @db.VarChar(200)
+  /// Registry URL on Global CarbonTrace for transparency
+  registryUrl         String?       @map("registry_url") @db.VarChar(500)
+
+  /// Aurigraph DLT — on-chain token address once minted
+  tokenAddress        String?       @unique @map("token_address") @db.VarChar(200)
+  tokenStandard       VccTokenStandard @map("token_standard") @default(SFT)
+  onChainMetadataHash String?       @map("on_chain_metadata_hash") @db.VarChar(255)
+
+  status              VccTokenStatus @default(PENDING_LOCK)
+  lockedAt            DateTime?     @map("locked_at")
+  mintedAt            DateTime?     @map("minted_at")
+  burnedAt            DateTime?     @map("burned_at")
+
+  /// Beneficiary who retired this credit (populated at burn)
+  beneficiaryName     String?       @map("beneficiary_name") @db.VarChar(255)
+  beneficiaryType     String?       @map("beneficiary_type") @db.VarChar(50)
+  retirementPurpose   String?       @map("retirement_purpose") @db.VarChar(500)
+  retirementStatementUrl String?    @map("retirement_statement_url") @db.VarChar(500)
+
+  createdAt           DateTime      @default(now()) @map("created_at")
+  updatedAt           DateTime      @updatedAt @map("updated_at")
+
+  partner             BiocarbonPartner @relation(fields: [partnerId], references: [id], onDelete: Restrict)
+  org                 Organization     @relation(fields: [orgId], references: [id], onDelete: Restrict)
+  transferHistory     VccTokenTransfer[]
+  auditEvents         VccTokenAuditEvent[]
+
+  @@index([orgId, status])
+  @@index([biocarbonSerialId])
+  @@index([vintage, projectCountry])
+  @@map("vcc_tokens")
+}
+
+/// BioCarbon mandates NFT or SFT (no pure fungible / pooling)
+enum VccTokenStandard {
+  NFT   @map("nft")   // ERC-721 equivalent — unique per credit
+  SFT   @map("sft")   // ERC-1155 equivalent — batch-efficient, recommended
+}
+
+enum VccTokenStatus {
+  PENDING_LOCK        @map("pending_lock")
+  LOCKED              @map("locked")          // VCC locked in BioCarbon registry
+  MINTED              @map("minted")          // Token live on Aurigraph DLT
+  LISTED              @map("listed")          // Available on marketplace
+  TRANSFERRED         @map("transferred")     // In secondary trade
+  PENDING_RETIREMENT  @map("pending_retirement")
+  BURNED              @map("burned")          // Token burned → VCC retired on registry
+  DELISTED            @map("delisted")        // Two-way bridge: back to off-chain
+}
+
+/// Immutable transfer record — every ownership change on-chain
+model VccTokenTransfer {
+  id              String   @id @default(uuid()) @db.Uuid
+  tokenId         String   @map("token_id") @db.Uuid
+  fromAddress     String?  @map("from_address") @db.VarChar(200)
+  toAddress       String   @map("to_address") @db.VarChar(200)
+  txHash          String   @unique @map("tx_hash") @db.VarChar(255)
+  blockHeight     BigInt?  @map("block_height")
+  transferType    VccTransferType @map("transfer_type")
+  transferredAt   DateTime @map("transferred_at")
+  createdAt       DateTime @default(now()) @map("created_at")
+
+  token           VccToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
+
+  @@index([tokenId])
+  @@index([txHash])
+  @@map("vcc_token_transfers")
+}
+
+enum VccTransferType {
+  MINT            @map("mint")
+  MARKETPLACE     @map("marketplace")
+  DIRECT          @map("direct")
+  RETIREMENT_BURN @map("retirement_burn")
+  DELISTING_BURN  @map("delisting_burn")
+}
+
+/// Full audit trail for every lifecycle event — BioCarbon compliance requirement
+model VccTokenAuditEvent {
+  id          String   @id @default(uuid()) @db.Uuid
+  tokenId     String   @map("token_id") @db.Uuid
+  eventType   VccAuditEventType @map("event_type")
+  actorId     String?  @map("actor_id") @db.Uuid
+  metadata    Json?
+  biocarbonApiResponse Json?   @map("biocarbon_api_response")
+  createdAt   DateTime @default(now()) @map("created_at")
+
+  token       VccToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
+
+  @@index([tokenId, eventType])
+  @@index([createdAt])
+  @@map("vcc_token_audit_events")
+}
+
+enum VccAuditEventType {
+  LOCK_REQUESTED      @map("lock_requested")
+  LOCK_CONFIRMED      @map("lock_confirmed")
+  MINT_INITIATED      @map("mint_initiated")
+  MINT_CONFIRMED      @map("mint_confirmed")
+  LISTED              @map("listed")
+  TRANSFER            @map("transfer")
+  RETIREMENT_REQUESTED @map("retirement_requested")
+  BURN_CONFIRMED      @map("burn_confirmed")
+  REGISTRY_RETIRED    @map("registry_retired")
+  DELISTED            @map("delisted")
+  UNLOCKED            @map("unlocked")
+  CHANGE_NOTIFICATION @map("change_notification")
+  COMPLIANCE_CHECK    @map("compliance_check")
+}
