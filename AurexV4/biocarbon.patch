+                <option value="SFT">SFT (recommended)</option>
+                <option value="NFT">NFT</option>
+              </select>
+            </Field>
+          </div>
+          <Field label="Methodology">
+            <input value={lockForm.methodology} onChange={(e) => setLockForm({ ...lockForm, methodology: e.target.value })} />
+          </Field>
+          <Field label="Registry URL">
+            <input placeholder="https://globalcarbontrace.io/..." value={lockForm.registryUrl} onChange={(e) => setLockForm({ ...lockForm, registryUrl: e.target.value })} />
+          </Field>
+          {formError && <div style={{ color: '#A32D2D', fontSize: 13, marginTop: 8 }}>{formError}</div>}
+          <div style={{ display: 'flex', justifyContent: 'flex-end', gap: 10, marginTop: 16 }}>
+            <button onClick={() => setModalOpen(null)} style={{ padding: '8px 16px', borderRadius: 6, border: '0.5px solid var(--color-border-secondary)', background: 'transparent', cursor: 'pointer', fontSize: 13 }}>
+              Cancel
+            </button>
+            <button onClick={submitLock} disabled={submitting}
+              style={{ padding: '8px 16px', borderRadius: 6, border: 'none', background: '#0F6E56', color: '#fff', cursor: 'pointer', fontSize: 13, fontWeight: 500 }}>
+              {submitting ? 'Locking…' : 'Lock VCC'}
+            </button>
+          </div>
+        </Modal>
+      )}
+
+      {/* Retire Modal */}
+      {modalOpen === 'retire' && selectedToken && (
+        <Modal title="Initiate Retirement" onClose={() => setModalOpen(null)}>
+          <div style={{ fontSize: 12, color: 'var(--color-text-secondary)', marginBottom: 12, fontFamily: 'monospace' }}>
+            Serial: {selectedToken.biocarbonSerialId}
+          </div>
+          <Field label="Beneficiary Name *">
+            <input value={retireForm.beneficiaryName} onChange={(e) => setRetireForm({ ...retireForm, beneficiaryName: e.target.value })} />
+          </Field>
+          <Field label="Beneficiary Type *">
+            <select value={retireForm.beneficiaryType} onChange={(e) => setRetireForm({ ...retireForm, beneficiaryType: e.target.value })}>
+              {['COMPANY', 'INDIVIDUAL', 'GOVERNMENT', 'NGO'].map((t) => <option key={t}>{t}</option>)}
+            </select>
+          </Field>
+          <Field label="Retirement Purpose *">
+            <input placeholder="Voluntary offset for 2024 GHG inventory" value={retireForm.retirementPurpose} onChange={(e) => setRetireForm({ ...retireForm, retirementPurpose: e.target.value })} />
+          </Field>
+          {formError && <div style={{ color: '#A32D2D', fontSize: 13, marginTop: 8 }}>{formError}</div>}
+          <div style={{ display: 'flex', justifyContent: 'flex-end', gap: 10, marginTop: 16 }}>
+            <button onClick={() => setModalOpen(null)} style={{ padding: '8px 16px', borderRadius: 6, border: '0.5px solid var(--color-border-secondary)', background: 'transparent', cursor: 'pointer', fontSize: 13 }}>
+              Cancel
+            </button>
+            <button onClick={submitRetire} disabled={submitting}
+              style={{ padding: '8px 16px', borderRadius: 6, border: 'none', background: '#993C1D', color: '#fff', cursor: 'pointer', fontSize: 13, fontWeight: 500 }}>
+              {submitting ? 'Submitting…' : 'Confirm Retirement'}
+            </button>
+          </div>
+        </Modal>
+      )}
+
+      {/* Burn confirmation Modal */}
+      {modalOpen === 'burn' && selectedToken && (
+        <Modal title="Burn Token & Retire VCC" onClose={() => setModalOpen(null)}>
+          <div style={{ fontSize: 13, color: 'var(--color-text-secondary)', marginBottom: 16, lineHeight: 1.6 }}>
+            This will permanently burn token <code style={{ fontSize: 11 }}>{selectedToken.tokenAddress}</code> and
+            trigger retirement of VCC <code style={{ fontSize: 11 }}>{selectedToken.biocarbonSerialId}</code> on
+            the BioCarbon registry. This action cannot be undone.
+          </div>
+          <div style={{ background: '#FAECE7', border: '0.5px solid #993C1D44', borderRadius: 8, padding: '12px 14px', fontSize: 13, color: '#993C1D', marginBottom: 16 }}>
+            Beneficiary: <strong>{selectedToken.beneficiaryName}</strong>
+          </div>
+          {formError && <div style={{ color: '#A32D2D', fontSize: 13, marginBottom: 8 }}>{formError}</div>}
+          <div style={{ display: 'flex', justifyContent: 'flex-end', gap: 10 }}>
+            <button onClick={() => setModalOpen(null)} style={{ padding: '8px 16px', borderRadius: 6, border: '0.5px solid var(--color-border-secondary)', background: 'transparent', cursor: 'pointer', fontSize: 13 }}>
+              Cancel
+            </button>
+            <button
+              disabled={submitting}
+              onClick={async () => {
+                setSubmitting(true);
+                setFormError('');
+                try {
+                  const txHash = `0x${Math.random().toString(16).slice(2)}`;
+                  const res = await fetch(`/api/v1/biocarbon/tokens/${selectedToken.id}/burn`, {
+                    method: 'POST', headers: { 'Content-Type': 'application/json' },
+                    body: JSON.stringify({ txHash }),
+                  });
+                  if (!res.ok) { const e = await res.json(); setFormError(e.message ?? 'Failed'); return; }
+                  setModalOpen(null);
+                  await load();
+                } finally { setSubmitting(false); }
+              }}
+              style={{ padding: '8px 16px', borderRadius: 6, border: 'none', background: '#A32D2D', color: '#fff', cursor: 'pointer', fontSize: 13, fontWeight: 500 }}>
+              {submitting ? 'Burning…' : 'Burn & Retire'}
+            </button>
+          </div>
+        </Modal>
+      )}
+    </div>
+  );
+}
+
+// ─── Small reusable pieces ───────────────────────────────────────────────────
+
+function ActionBtn({ label, color, onClick }: { label: string; color: string; onClick: () => void }) {
+  return (
+    <button
+      onClick={onClick}
+      style={{
+        padding: '3px 8px', fontSize: 11, borderRadius: 4, cursor: 'pointer',
+        border: `0.5px solid ${color}44`, background: `${color}11`, color, fontWeight: 500,
+      }}
+    >
+      {label}
+    </button>
+  );
+}
+
+function Modal({ title, children, onClose }: { title: string; children: React.ReactNode; onClose: () => void }) {
+  return (
+    <div style={{ position: 'fixed', inset: 0, background: 'rgba(0,0,0,0.45)', display: 'flex', alignItems: 'center', justifyContent: 'center', zIndex: 1000 }}>
+      <div style={{ background: 'var(--color-background-primary)', border: '0.5px solid var(--color-border-tertiary)', borderRadius: 12, padding: '24px', width: 520, maxHeight: '90vh', overflowY: 'auto' }}>
+        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20 }}>
+          <h2 style={{ margin: 0, fontSize: 16, fontWeight: 500 }}>{title}</h2>
+          <button onClick={onClose} style={{ background: 'none', border: 'none', cursor: 'pointer', fontSize: 18, color: 'var(--color-text-secondary)' }}>×</button>
+        </div>
+        {children}
+      </div>
+    </div>
+  );
+}
+
+function Field({ label, hint, children }: { label: string; hint?: string; children: React.ReactNode }) {
+  return (
+    <div style={{ marginBottom: 12 }}>
+      <label style={{ display: 'block', fontSize: 12, fontWeight: 500, color: 'var(--color-text-secondary)', marginBottom: 4 }}>{label}</label>
+      {hint && <div style={{ fontSize: 11, color: 'var(--color-text-secondary)', marginBottom: 4 }}>{hint}</div>}
+      <div style={{ width: '100%' }}>{children}</div>
+    </div>
+  );
+}
