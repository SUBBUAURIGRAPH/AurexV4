+/**
+ * biocarbon.ts — shared Zod schemas for BioCarbon VCC tokenization
+ * Used by API validation and frontend form inference.
+ */
+import { z } from 'zod';
+
+export const BiocarbonPartnerStatusSchema = z.enum([
+  'PENDING',
+  'AUTHORIZED',
+  'SUSPENDED',
+  'REVOKED',
+]);
+
+export const VccTokenStatusSchema = z.enum([
+  'PENDING_LOCK',
+  'LOCKED',
+  'MINTED',
+  'LISTED',
+  'TRANSFERRED',
+  'PENDING_RETIREMENT',
+  'BURNED',
+  'DELISTED',
+]);
+
+export const VccTokenStandardSchema = z.enum(['NFT', 'SFT']);
+
+export const VccLockRequestSchema = z.object({
+  biocarbonSerialId: z
+    .string()
+    .min(1)
+    .max(200)
+    .describe('BioCarbon serial ID — e.g. BCR-CO-123-1-001-2-2001-2012-00001-12345'),
+  vintage: z.number().int().min(2000).max(2100),
+  projectId: z.string().min(1).max(100),
+  projectTitle: z.string().min(1).max(500),
+  projectCountry: z.string().length(2).describe('ISO-3166-1 alpha-2'),
+  methodology: z.string().max(200).optional(),
+  registryUrl: z.string().url().optional(),
+  tokenStandard: VccTokenStandardSchema.default('SFT'),
+});
+
+export const VccBeneficiarySchema = z.object({
+  beneficiaryName: z.string().min(1).max(255),
+  beneficiaryType: z.enum(['INDIVIDUAL', 'COMPANY', 'GOVERNMENT', 'NGO']),
+  retirementPurpose: z.string().min(1).max(500),
+});
+
+export type VccLockRequest = z.infer<typeof VccLockRequestSchema>;
+export type VccBeneficiary = z.infer<typeof VccBeneficiarySchema>;
+export type VccTokenStatus = z.infer<typeof VccTokenStatusSchema>;
+export type VccTokenStandard = z.infer<typeof VccTokenStandardSchema>;
-- 
