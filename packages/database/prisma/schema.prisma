// ─── Article 6.4 / PACM (Paris Agreement Crediting Mechanism) ───────────
// Rulebook: FCCC/PA/CMA/2021/10/Add.1 (Decision 3/CMA.3) + SB standards.
// Gap-analysis addition per /Users/subbujois/.claude/plans/tidy-soaring-pancake.md

/// Approved methodology from UNFCCC Supervisory Body (A6.4-STAN-METH-*).
/// Read-only catalogue seeded from UNFCCC registry; not user-editable.
model Methodology {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique @db.VarChar(100) // e.g. "A6.4-STAN-METH-004"
  name            String   @db.VarChar(255)
  version         String   @db.VarChar(32)
  category        MethodologyCategory
  sectoralScope   Int? // 1-15 per UNFCCC sectoral scopes
  summary         String?  @db.Text
  referenceUrl    String?  @map("reference_url") @db.VarChar(500)
  effectiveFrom   DateTime @map("effective_from")
  supersededAt    DateTime? @map("superseded_at")
  isActive        Boolean  @default(true) @map("is_active")
  /// BioCarbon Registry (BCR) Third-Party tokenisation eligibility flag.
  /// Set to true for methodologies whose VCC issuances may participate in
  /// BCR's lock-then-mint flow (B6 of BIOCARBON_TOKENIZATION_GUIDELINES_RESEARCH).
  /// Read-only; toggled via the master-data seed.
  isBcrEligible   Boolean  @default(false) @map("is_bcr_eligible")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  activities Activity[]

  @@index([category, isActive])
  @@map("methodologies")
}

enum MethodologyCategory {
  BASELINE_AND_MONITORING @map("baseline_and_monitoring")
  REMOVAL                 @map("removal")
  SMALL_SCALE             @map("small_scale")
  CONSOLIDATED            @map("consolidated")
  CDM_TRANSITION          @map("cdm_transition")
}

/// An A6.4 mitigation activity (project or programme of activities).
/// Project-level, NOT org-level — this is the key distinction from
/// EmissionsRecord which is an org-wide inventory entry.
model Activity {
  id                  String   @id @default(uuid()) @db.Uuid
  orgId               String   @map("org_id") @db.Uuid
  methodologyId       String   @map("methodology_id") @db.Uuid
  title               String   @db.VarChar(255)
  description         String?  @db.Text
  hostCountry         String   @map("host_country") @db.VarChar(2) // ISO-3166 alpha-2
  sectoralScope       Int      @map("sectoral_scope") // 1-15 per UNFCCC
  technologyType      String   @map("technology_type") @db.VarChar(100)
  geoBoundary         Json?    @map("geo_boundary") // GeoJSON polygon / MultiPolygon
  gasesCovered        String[] @map("gases_covered") // ["CO2","CH4","N2O","HFCs","PFCs","SF6","NF3"]
  creditingPeriodType ActivityCreditingPeriodType @map("crediting_period_type")
  creditingPeriodStart DateTime? @map("crediting_period_start")
  creditingPeriodEnd   DateTime? @map("crediting_period_end")
  renewalCount         Int      @default(0) @map("renewal_count")
  expectedAnnualEr     Decimal? @map("expected_annual_er") @db.Decimal(18, 3) // tCO2e/yr
  status              ActivityStatus @default(DRAFT)
  isRemoval           Boolean  @default(false) @map("is_removal") // triggers buffer pool reqs
  /// Reversal-risk buffer pool contribution (% of NET units) applied to removal
  /// activities at issuance. Default 20% per SB removals-tool baseline. AAT-2
  /// uses this on mint to deposit into the REVERSAL_BUFFER admin account.
  bufferPoolContributionPct Decimal @default(20.00) @db.Decimal(5, 2) @map("buffer_pool_pct")
  cdmTransition       Boolean  @default(false) @map("cdm_transition") // legacy CDM migrating
  cdmReference        String?  @map("cdm_reference") @db.VarChar(50) // e.g. "CDM-1234"
  submittedAt         DateTime? @map("submitted_at")
  registeredAt        DateTime? @map("registered_at")
  closedAt            DateTime? @map("closed_at")
  createdBy           String   @map("created_by") @db.Uuid
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  org            Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  methodology    Methodology         @relation(fields: [methodologyId], references: [id])
  pdd            Pdd?
  hostAuthorization HostAuthorization?
  validationReport  ValidationReport?
  monitoringPlan    MonitoringPlan?
  monitoringPeriods MonitoringPeriod[]
  issuances         Issuance[]
  creditAccount     CreditAccount?
  baselineScenarios BaselineScenario[]
  sdContributions   SdContribution[]

  @@index([orgId, status])
  @@index([methodologyId])
  @@index([hostCountry])
  @@map("activities")
}

enum ActivityCreditingPeriodType {
  RENEWABLE_5YR  @map("renewable_5yr")   // up to 3 × 5yr (15yr max)
  FIXED_10YR     @map("fixed_10yr")
  REMOVAL_15YR   @map("removal_15yr")    // removals: up to 3 × 15yr (45yr max)
}

enum ActivityStatus {
  DRAFT              @map("draft")
  SUBMITTED          @map("submitted")
  VALIDATING         @map("validating")
  VALIDATED          @map("validated")
  AWAITING_HOST      @map("awaiting_host")      // waiting on LoA
  REGISTERED         @map("registered")
  ISSUING            @map("issuing")
  CLOSED             @map("closed")
  REJECTED           @map("rejected")
}

/// Project Design Document (PDD) — narrative + technical spec per activity.
model Pdd {
  id            String   @id @default(uuid()) @db.Uuid
  activityId    String   @unique @map("activity_id") @db.Uuid
