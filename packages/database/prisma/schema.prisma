  @@map("monitoring_plans")
}

model MonitoringParameter {
  id             String   @id @default(uuid()) @db.Uuid
  planId         String   @map("plan_id") @db.Uuid
  code           String   @db.VarChar(64) // e.g. "EC_y" (electricity consumption year y)
  name           String   @db.VarChar(255)
  unit           String   @db.VarChar(32)
  measurementMethod MeasurementMethod @map("measurement_method")
  frequency      String   @db.VarChar(64) // "continuous" | "daily" | "monthly" | "annual" | campaign text
  equipment      String?  @db.Text
  uncertaintyPct Decimal? @map("uncertainty_pct") @db.Decimal(6, 3)
  createdAt      DateTime @default(now()) @map("created_at")

  plan       MonitoringPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  datapoints MonitoringDatapoint[]

  @@unique([planId, code])
  @@map("monitoring_parameters")
}

enum MeasurementMethod {
  DIRECT      @map("direct")       // metered
  CALCULATED  @map("calculated")   // derived from measured inputs
  DEFAULT     @map("default")      // IPCC / grid default factor
  ESTIMATED   @map("estimated")    // expert judgement
}

/// A period the activity is monitored over; one verification report per period.
model MonitoringPeriod {
  id          String   @id @default(uuid()) @db.Uuid
  activityId  String   @map("activity_id") @db.Uuid
  periodStart DateTime @map("period_start")
  periodEnd   DateTime @map("period_end")
  status      MonitoringPeriodStatus @default(OPEN)
  submittedAt DateTime? @map("submitted_at")
  submittedBy String?   @map("submitted_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  activity           Activity            @relation(fields: [activityId], references: [id], onDelete: Cascade)
  datapoints         MonitoringDatapoint[]
  verificationReport VerificationReport?
  issuance           Issuance?
  sdContributions    SdContribution[]

  @@index([activityId, periodStart])
  @@map("monitoring_periods")
}

enum MonitoringPeriodStatus {
  OPEN        @map("open")
  SUBMITTED   @map("submitted")
  VERIFYING   @map("verifying")
  VERIFIED    @map("verified")
  ISSUED      @map("issued")
  REJECTED    @map("rejected")
}

/// Raw measurement within a monitoring period.
model MonitoringDatapoint {
  id           String   @id @default(uuid()) @db.Uuid
  periodId     String   @map("period_id") @db.Uuid
  parameterId  String   @map("parameter_id") @db.Uuid
  timestamp    DateTime
  rawValue     Decimal  @map("raw_value") @db.Decimal(24, 6)
  adjustedValue Decimal? @map("adjusted_value") @db.Decimal(24, 6)
  provenance   DataProvenance
  sourceRef    String?  @map("source_ref") @db.VarChar(500) // meter-id / invoice-id / satellite-tile / form-id
  uncertaintyPct Decimal? @map("uncertainty_pct") @db.Decimal(6, 3)
  notes        String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  period    MonitoringPeriod   @relation(fields: [periodId], references: [id], onDelete: Cascade)
  parameter MonitoringParameter @relation(fields: [parameterId], references: [id])

  @@index([periodId, timestamp])
  @@map("monitoring_datapoints")
}

enum DataProvenance {
  METER      @map("meter")
  INVOICE    @map("invoice")
  SATELLITE  @map("satellite")
  SURVEY     @map("survey")
  LABORATORY @map("laboratory")
  CALCULATED @map("calculated")
}

/// DOE verification of a monitoring period — ex-post check of actual ER.
model VerificationReport {
  id                  String   @id @default(uuid()) @db.Uuid
  periodId            String   @unique @map("period_id") @db.Uuid
  doeUserId           String   @map("doe_user_id") @db.Uuid
  doeOrgName          String   @map("doe_org_name") @db.VarChar(255)
  doeAccreditationId  String?  @map("doe_accreditation_id") @db.VarChar(100)
  methodologyVersion  String   @map("methodology_version") @db.VarChar(32)
  baselineEmissions   Decimal  @map("baseline_emissions") @db.Decimal(18, 3) // tCO2e
  projectEmissions    Decimal  @map("project_emissions") @db.Decimal(18, 3)
  leakageEmissions    Decimal  @map("leakage_emissions") @db.Decimal(18, 3)
  verifiedEr          Decimal  @map("verified_er") @db.Decimal(18, 3) // = baseline − project − leakage (or removal form)
  conservativeness    Decimal? @map("conservativeness") @db.Decimal(6, 3) // discount %
  opinion             DoeOpinion
  findings            Json?
  documentUrl         String?  @map("document_url") @db.VarChar(500)
  verifiedAt          DateTime @map("verified_at")
  createdAt           DateTime @default(now()) @map("created_at")

  period MonitoringPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@map("verification_reports")
}

/// Issuance request → mints A6.4ER units. Auto-levies SOP (5%) + OMGE (2%).
/// Net to activity participant = gross × 0.93.
model Issuance {
  id                  String   @id @default(uuid()) @db.Uuid
  activityId          String   @map("activity_id") @db.Uuid
  periodId            String   @unique @map("period_id") @db.Uuid
  grossUnits          Decimal  @map("gross_units") @db.Decimal(18, 3)   // = verifiedEr rounded down to whole tCO2e
  sopLevyUnits        Decimal  @map("sop_levy_units") @db.Decimal(18, 3) // 5% SOP → Adaptation Fund
  omgeCancelledUnits  Decimal  @map("omge_cancelled_units") @db.Decimal(18, 3) // 2% OMGE auto-cancel
  netUnits            Decimal  @map("net_units") @db.Decimal(18, 3)     // = gross × 0.93
  vintage             Int      // year of emission reductions
  unitType            CreditUnitType @map("unit_type")
  status              IssuanceStatus @default(REQUESTED)
  requestedBy         String   @map("requested_by") @db.Uuid
  requestedAt         DateTime @default(now()) @map("requested_at")
  issuedAt            DateTime? @map("issued_at")
  serialBlockId       String?  @map("serial_block_id") @db.Uuid
  // ── Biocarbon Sprint 2 — SDK tokenization (AAT-ε / AV4-373) ──────────────
  // Append-only mint trail. Populated by `tokenization.service.ts` after a
  // successful BCR lock + Aurigraph DLT `contracts.deploy(UC_CARBON, …)`.
  // Idempotency: presence of `tokenizationContractId` short-circuits a
  // re-tokenize call. None of these fields ever transition back to NULL —
  // a failed mint records FAILED + leaves contract/tx fields unset.
  tokenizationStatus     TokenizationStatus? @map("tokenization_status")
  tokenizationContractId String?  @map("tokenization_contract_id") @db.VarChar(255)
  tokenizationTxHash     String?  @map("tokenization_tx_hash") @db.VarChar(255)
  bcrSerialId            String?  @map("bcr_serial_id") @db.VarChar(255)
  bcrLockId              String?  @map("bcr_lock_id") @db.VarChar(255)
  tokenizedAt            DateTime? @map("tokenized_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  activity    Activity          @relation(fields: [activityId], references: [id])
  period      MonitoringPeriod  @relation(fields: [periodId], references: [id])
  serialBlock CreditUnitBlock?  @relation(fields: [serialBlockId], references: [id])
  aurigraphProcessedEvents AurigraphProcessedEvent[]
  retirements Retirement[]

  @@index([activityId, status])
  @@index([tokenizationContractId])
  @@index([bcrSerialId])
  @@map("issuances")
}

enum IssuanceStatus {
  REQUESTED   @map("requested")
  APPROVED    @map("approved")
  ISSUED      @map("issued")
  REJECTED    @map("rejected")
  RETIRED     @map("retired")    // AAT-ζ / AV4-375: set on burn-for-retirement event
}

/// Biocarbon SDK tokenization lifecycle (AAT-ε / AV4-373). Populated on
/// `Issuance.tokenizationStatus` after `tokenization.service.tokenizeIssuance`.
///
///   PENDING — lock acquired, mint attempted but not yet observed durable
///   MINTED  — `contracts.deploy(UC_CARBON, …)` succeeded; contractId + txHash set
///   FAILED  — confirmLock or deployContract failed; lock released best-effort
enum TokenizationStatus {
  PENDING @map("pending")
  MINTED  @map("minted")
  FAILED  @map("failed")
}

enum CreditUnitType {
  A6_4ER      @map("a64er")       // authorized → carries CA on first transfer
  A6_4ER_MC   @map("a64er_mc")    // mitigation contribution — no international transfer, no CA
}

/// A block of contiguous A6.4ER serials issued in a single issuance event.
/// Range-compressed: one row represents many individual units.
model CreditUnitBlock {
  id            String   @id @default(uuid()) @db.Uuid
  serialFirst   String   @map("serial_first") @db.VarChar(128)
  serialLast    String   @map("serial_last") @db.VarChar(128)
  unitCount     Decimal  @map("unit_count") @db.Decimal(18, 3)
  unitType      CreditUnitType @map("unit_type")
  vintage       Int
  activityId    String   @map("activity_id") @db.Uuid
  hostCountry   String   @map("host_country") @db.VarChar(2)
  issuanceDate  DateTime @map("issuance_date")
  holderAccountId String @map("holder_account_id") @db.Uuid
  authorizationStatus AuthorizationScope @map("authorization_status")
  caStatus      CorrespondingAdjustmentStatus @default(NOT_REQUIRED) @map("ca_status")
  firstTransferAt DateTime? @map("first_transfer_at")
  retirementStatus RetirementStatus @default(ACTIVE) @map("retirement_status")
  retirementNarrative String? @map("retirement_narrative") @db.Text
  retiredAt     DateTime? @map("retired_at")
  retiredBy     String?   @map("retired_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  holderAccount CreditAccount @relation(fields: [holderAccountId], references: [id])
  issuances     Issuance[]
  transactions  Transaction[]

  @@index([activityId])
  @@index([holderAccountId])
  @@index([retirementStatus])
  @@map("credit_unit_blocks")
}

enum CorrespondingAdjustmentStatus {
  NOT_REQUIRED  @map("not_required")   // unit_type = A6_4ER_MC
  PENDING       @map("pending")        // authorized, pre-first-transfer
  APPLIED       @map("applied")        // CA emitted to host Party BTR
  REVERSED      @map("reversed")
}

enum RetirementStatus {
  ACTIVE              @map("active")
  RETIRED_FOR_NDC     @map("retired_for_ndc")
  RETIRED_FOR_OIMP    @map("retired_for_oimp")
  RETIRED_VOLUNTARY   @map("retired_voluntary")
  CANCELLED_OMGE      @map("cancelled_omge")     // at issuance
  CANCELLED_SOP       @map("cancelled_sop")      // held by Adaptation Fund
  CANCELLED_REVERSAL  @map("cancelled_reversal") // removal buffer pool draw
  CANCELLED_OTHER     @map("cancelled_other")
}

/// Registry account. Activity participants + host Parties + SB admin accounts.
model CreditAccount {
  id          String   @id @default(uuid()) @db.Uuid
  accountType CreditAccountType @map("account_type")
  name        String   @db.VarChar(255)
  orgId       String?  @map("org_id") @db.Uuid        // for ACTIVITY_PARTICIPANT + HOST_PARTY
  activityId  String?  @unique @map("activity_id") @db.Uuid // for ACTIVITY_PARTICIPANT (1:1 with activity)
  hostCountry String?  @map("host_country") @db.VarChar(2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  org      Organization?      @relation(fields: [orgId], references: [id], onDelete: SetNull)
  activity Activity?          @relation(fields: [activityId], references: [id], onDelete: SetNull)
  holdings CreditUnitBlock[]
  transactionsFrom Transaction[] @relation("transactionsFrom")
  transactionsTo   Transaction[] @relation("transactionsTo")

  @@index([orgId])
  @@index([accountType])
  @@map("credit_accounts")
}

enum CreditAccountType {
  ACTIVITY_PARTICIPANT   @map("activity_participant")
  HOST_PARTY             @map("host_party")
  ADAPTATION_FUND        @map("adaptation_fund")     // SOP destination
  OMGE_CANCELLATION      @map("omge_cancellation")   // 2% auto-cancel destination
  REVERSAL_BUFFER        @map("reversal_buffer")     // removal activities
  RETIREMENT_NDC         @map("retirement_ndc")
  RETIREMENT_OIMP        @map("retirement_oimp")
  RETIREMENT_VOLUNTARY   @map("retirement_voluntary")
}

/// CA event emitted on first international transfer of an authorized A6.4ER block.
/// Host Party applies the adjustment in its next Biennial Transparency Report.
model CorrespondingAdjustmentEvent {
  id              String   @id @default(uuid()) @db.Uuid
  blockId         String   @map("block_id") @db.Uuid
  hostCountry     String   @map("host_country") @db.VarChar(2)
  buyerCountry    String?  @map("buyer_country") @db.VarChar(2)
  units           Decimal  @db.Decimal(18, 3)
  vintage         Int
  triggeredAt     DateTime @default(now()) @map("triggered_at")
  btrExportedAt   DateTime? @map("btr_exported_at")
  status          CaEventStatus @default(PENDING_EXPORT)
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([hostCountry, status])
  @@index([blockId])
  @@map("corresponding_adjustment_events")
}

enum CaEventStatus {
  PENDING_EXPORT @map("pending_export")
  EXPORTED       @map("exported")
  ACKNOWLEDGED   @map("acknowledged") // host DNA confirmed in BTR
  REVERSED       @map("reversed")
}

// ─── A6.4 BaselineScenario (AV4-336, per A6.4-STAN-METH-004) ───────────
// Structured per-activity baseline with per-year emissions and
// downward-adjustment factor. DOE approves the scenario before it can
// be used in verification.

model BaselineScenario {
  id                         String @id @default(uuid()) @db.Uuid
  activityId                 String @map("activity_id") @db.Uuid
  version                    Int    @default(1)
  status                     BaselineScenarioStatus @default(DRAFT)
  narrative                  String @db.Text
  methodologyVersion         String @db.VarChar(32)
  ndcAlignmentJustification  String? @db.Text
  ltLedsReference            String? @db.VarChar(500)
  suppressedDemandFlag       Boolean @default(false)
  suppressedDemandNotes      String? @db.Text
  approvedBy                 String? @db.Uuid
  approvedAt                 DateTime?
  supersededAt               DateTime?
  createdBy                  String @db.Uuid
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  activity  Activity         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  emissions BaselineEmission[]

  @@unique([activityId, version])
  @@index([status])
  @@map("baseline_scenarios")
}

enum BaselineScenarioStatus {
  DRAFT      @map("draft")
  SUBMITTED  @map("submitted")
  APPROVED   @map("approved")
  SUPERSEDED @map("superseded")
  REJECTED   @map("rejected")
}

model BaselineEmission {
  id                        String @id @default(uuid()) @db.Uuid
  scenarioId                String @map("scenario_id") @db.Uuid
  year                      Int
  emissionsTco2e            Decimal @db.Decimal(18,3)
  downwardAdjustmentFactor  Decimal @default(1.0) @db.Decimal(6,4)
  notes                     String? @db.Text
  createdAt                 DateTime @default(now())

  scenario BaselineScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@unique([scenarioId, year])
  @@map("baseline_emissions")
}

// ─── A6.4 SD-Tool (AV4-337) ─────────────────────────────────────────────
// Sustainable Development Tool — mandatory since 2024 for PACM activities.
// Tracks contributions across the 17 UN SDGs via structured indicators,
// distinguishing ex-ante (PDD-stage) from ex-post (per monitoring period).

model Sdg {
  code        String @id @db.VarChar(16)  // "SDG_1" .. "SDG_17"
  name        String @db.VarChar(100)
  description String @db.Text
  iconUrl     String? @db.VarChar(500)
  isActive    Boolean @default(true)

  indicators SdIndicator[]

  @@map("sdgs")
}

model SdIndicator {
  code                String @id @db.VarChar(32)  // "SDG_7.1"
  sdgCode             String @map("sdg_code") @db.VarChar(16)
  name                String @db.VarChar(255)
  description         String @db.Text
  unit                String @db.VarChar(32)
  measurementGuidance String? @db.Text
  isActive            Boolean @default(true)

  sdg          Sdg                @relation(fields: [sdgCode], references: [code])
  contributions SdContribution[]

  @@index([sdgCode])
  @@map("sd_indicators")
}

model SdContribution {
  id                String @id @default(uuid()) @db.Uuid
  activityId        String @map("activity_id") @db.Uuid
  indicatorCode     String @map("indicator_code") @db.VarChar(32)
  contributionType  SdContributionType
  monitoringPeriodId String? @map("monitoring_period_id") @db.Uuid
  value             Decimal @db.Decimal(18,3)
  unit              String @db.VarChar(32)
  notes             String? @db.Text
  evidenceUrl       String? @map("evidence_url") @db.VarChar(500)
  updatedBy         String @map("updated_by") @db.Uuid
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  activity         Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  indicator        SdIndicator       @relation(fields: [indicatorCode], references: [code])
  monitoringPeriod MonitoringPeriod? @relation(fields: [monitoringPeriodId], references: [id], onDelete: Cascade)

  @@unique([activityId, indicatorCode, contributionType, monitoringPeriodId])
  @@index([activityId])
  @@map("sd_contributions")
}

enum SdContributionType {
  EX_ANTE @map("ex_ante")
  EX_POST @map("ex_post")
}

// ─── A6.4 Retention policy (AV4-338) ─────────────────────────────────────
// Raw monitoring data must be retained ≥ 2 years after crediting-period end
// per A6.4-PROC-AC-002 + Decision 3/CMA.3. Data is moved to cold storage
// (blob store) rather than deleted. Never purge.

model RetentionPolicy {
  id                String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(100)
  description       String?  @db.Text
  minRetentionYears Int      @default(2) @map("min_retention_years") // ≥ 2yr post-end-of-crediting-period per A6.4-PROC-AC-002
  ruleJson          Json?    @map("rule_json")
  isDefault         Boolean  @default(false) @map("is_default")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("retention_policies")
}

/// Record of a monitoring period whose datapoints have been archived to
/// cold blob storage. The Postgres datapoint rows have been deleted and can
/// be re-hydrated from `archiveUrl` after SHA-256 verification.
model DatapointArchive {
  id             String   @id @default(uuid()) @db.Uuid
  periodId       String   @unique @map("period_id") @db.Uuid
  archivedAt     DateTime @default(now()) @map("archived_at")
  archiveUrl     String   @map("archive_url") @db.VarChar(1000)
  archiveFormat  String   @default("jsonl.gz") @map("archive_format") @db.VarChar(16)
  rowCount       Int      @map("row_count")
  checksumSha256 String   @map("checksum_sha256") @db.VarChar(64)
  restoreCount   Int      @default(0) @map("restore_count")
  bytes          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("datapoint_archives")
}

// ─── Article 6.4 Phase C — Transaction ledger ──────────────────────────────
// Immutable append-only record of every transfer / retirement / cancellation
// applied to a CreditUnitBlock. Pairs with the block state machine — the
// block row holds CURRENT state; Transaction rows hold HISTORY.

enum TransactionType {
  TRANSFER         @map("transfer")
  RETIREMENT       @map("retirement")
  CANCELLATION     @map("cancellation")
  REVERSAL_DRAW    @map("reversal_draw")   // buffer-pool draw on post-issuance reversal
  ISSUANCE_MINT    @map("issuance_mint")   // synthetic row for the mint event itself
}

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid
  transactionType TransactionType @map("transaction_type")
  blockId         String          @map("block_id") @db.Uuid
  fromAccountId   String?         @map("from_account_id") @db.Uuid
  toAccountId     String          @map("to_account_id") @db.Uuid
  units           Decimal         @db.Decimal(18, 3)
  actorUserId     String          @map("actor_user_id") @db.Uuid
  narrative       String          @db.Text
  caEventId       String?         @map("ca_event_id") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")

  block       CreditUnitBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  fromAccount CreditAccount?  @relation("transactionsFrom", fields: [fromAccountId], references: [id])
  toAccount   CreditAccount   @relation("transactionsTo",   fields: [toAccountId],   references: [id])

  @@index([blockId, createdAt])
  @@index([fromAccountId])
  @@index([toAccountId])
  @@index([transactionType, createdAt])
  @@map("transactions")
}

// ─── Article 6.4 Phase C — UNFCCC central registry sync audit trail ────────
// Append-only record of every adapter call made against the UNFCCC A6.4
// mechanism registry (issuance, first-transfer, retirement notifications).
// The real registry API spec is pending CMA.6+; in the meantime the default
// adapter is `disabled` and every call lands here with `synced=false` plus a
// reason. When the spec publishes and an operator flips
// UNFCCC_REGISTRY_ADAPTER to a live adapter, successful calls land here with
// the external registry ref so we have an auditable sync history.

enum UnfcccSyncEventType {
  ISSUANCE        @map("issuance")
  FIRST_TRANSFER  @map("first_transfer")
  RETIREMENT      @map("retirement")
}

model UnfcccRegistrySyncEvent {
  id             String              @id @default(uuid()) @db.Uuid
  eventType      UnfcccSyncEventType @map("event_type")
  resourceKind   String              @map("resource_kind") @db.VarChar(64)   // "issuance" | "block" | "transaction"
  resourceId     String              @map("resource_id") @db.Uuid
  adapterName    String              @map("adapter_name") @db.VarChar(64)
  externalRef    String?             @map("external_ref") @db.VarChar(255)
  synced         Boolean             @default(false)
  reason         String?             @db.Text
  requestPayload Json?               @map("request_payload")
  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([resourceKind, resourceId])
  @@index([synced, createdAt])
  @@map("unfccc_registry_sync_events")
}

// ─── BioCarbon Registry adapter sync events (AV4-345) ──────────────────────
// Append-only audit trail for every call into the BCR registry adapter
// (lock / confirm-lock / notify-mint / notify-transfer / notify-burn /
// unlock / retire / get-status). Mirrors the UNFCCC-adapter audit pattern
// from AAT-5 so the operator has a single observability surface for all
// external-registry sync activity.
//
// The default adapter is `disabled` (BCR Third-Party authorisation pending
// per binding requirement B1). Calls land here with `synced=false` and a
// reason. When the operator flips `BCR_REGISTRY_ADAPTER` to a live adapter,
// successful calls land with `bcrSerialId` / `bcrLockId` / `externalRef`
// populated so the lock-then-mint chain is fully reconstructible.

model BcrRegistrySyncEvent {
  id              String           @id @default(uuid()) @db.Uuid
  eventType       BcrSyncEventType @map("event_type")
  resourceKind    String           @map("resource_kind") @db.VarChar(64)   // "issuance" | "block" | "transaction" | "lock"
  resourceId      String           @map("resource_id") @db.Uuid
  adapterName     String           @map("adapter_name") @db.VarChar(64)
  bcrSerialId     String?          @map("bcr_serial_id") @db.VarChar(255)
  bcrLockId       String?          @map("bcr_lock_id") @db.VarChar(255)
  externalRef     String?          @map("external_ref") @db.VarChar(255)
  synced          Boolean          @default(false)
  reason          String?          @db.Text
  requestPayload  Json?            @map("request_payload")
  responsePayload Json?            @map("response_payload")
  createdAt       DateTime         @default(now()) @map("created_at")

  @@index([resourceKind, resourceId])
  @@index([synced, createdAt])
  @@index([bcrSerialId])
  @@map("bcr_registry_sync_events")
}

enum BcrSyncEventType {
  LOCK_VCC        @map("lock_vcc")
  CONFIRM_LOCK    @map("confirm_lock")
  NOTIFY_MINT     @map("notify_mint")
  NOTIFY_TRANSFER @map("notify_transfer")
  NOTIFY_BURN     @map("notify_burn")
  UNLOCK_VCC      @map("unlock_vcc")
  RETIRE_VCC      @map("retire_vcc")
  GET_STATUS      @map("get_status")
}

// ─── Biocarbon Sprint 3 — Retirement payload (AAT-ι / AV4-358) ─────────────
// Records the marketplace-side retirement initiation: payload validated +
// chain burn fired. The events worker (AAT-ζ) reconciles the BCR side once
// the burn settles (BURN_FOR_RETIREMENT event → bcrAdapter.retireVCC), and
// flips status here from CHAIN_BURNED → BCR_SYNCED.
//
// Idempotency: `(issuanceId, kycVerificationId)` is unique. Re-calling the
// retirement service with the same KYC + issuance returns the existing row
// instead of double-burning.

model Retirement {
  id                       String                  @id @default(uuid()) @db.Uuid
  issuanceId               String                  @map("issuance_id") @db.Uuid
  issuance                 Issuance                @relation(fields: [issuanceId], references: [id])
  kycVerificationId        String                  @map("kyc_verification_id") @db.Uuid
  bcrSerialId              String                  @map("bcr_serial_id") @db.VarChar(255)
  tonnesRetired            Int                     @map("tonnes_retired")
  vintage                  Int
  purpose                  RetirementPurpose
  purposeNarrative         String?                 @map("purpose_narrative") @db.Text
  retiredFor               Json                    @map("retired_for")
  retiredByUserId          String                  @map("retired_by_user_id") @db.Uuid
  retiredByOrgId           String                  @map("retired_by_org_id") @db.Uuid
  retirementCertificateUrl String?                 @map("retirement_certificate_url") @db.VarChar(2048)
  txHash                   String?                 @map("tx_hash") @db.VarChar(255)
  status                   RetirementInitiationStatus @default(INITIATED)
  bcrSyncedAt              DateTime?               @map("bcr_synced_at")
  createdAt                DateTime                @default(now()) @map("created_at")
  updatedAt                DateTime                @updatedAt @map("updated_at")

  @@unique([issuanceId, kycVerificationId])
  @@index([bcrSerialId])
  @@index([status])
  @@map("retirements")
}

enum RetirementPurpose {
  CSR          @map("csr")
  NDC_OFFSET   @map("ndc_offset")
  CORSIA
  PROGRAMMATIC
  OTHER
}

/// Lifecycle of a marketplace-initiated retirement (AAT-ι / AV4-358).
/// Distinct from the existing `RetirementStatus` enum (which describes a
/// CreditUnitBlock's terminal state under A6.4 accounting).
///
///   INITIATED    — payload accepted + persisted; chain burn pending
///   CHAIN_BURNED — aurigraphAdapter.burnAsset returned txHash
///   BCR_SYNCED   — events worker forwarded retire to BCR; statement issued
///   FAILED       — chain burn failed or unrecoverable error
enum RetirementInitiationStatus {
  INITIATED    @map("initiated")
  CHAIN_BURNED @map("chain_burned")
  BCR_SYNCED   @map("bcr_synced")
  FAILED       @map("failed")
}

// ─── Biocarbon Sprint 2 — Aurigraph DLT SDK call audit log ─────────────────
// Append-only audit trail for every call made through AurigraphDltAdapter
// (apps/api/src/services/chains/aurigraph-dlt-adapter.ts) into the Aurigraph
// V12 platform via @aurigraph/dlt-sdk. Captures method, params, response refs
// (contractId / txHash if applicable), latency, and final status (including
// retried + failed). Best-effort write — adapter swallows any logging error
// so audit failures never break a contract deploy / transfer / burn.
//
// Used by AAT-β / AV4-370, AV4-372 (chain-adapter swap-in for biocarbon).

enum AurigraphCallStatus {
  PENDING @map("pending")
  SUCCESS @map("success")
  FAILED  @map("failed")
  RETRIED @map("retried")
}

model AurigraphCallLog {
  id          String              @id @default(uuid()) @db.Uuid
  method      String              @db.VarChar(64) // "contracts.deploy" / "assets.listByUseCase" / etc.
  params      Json?
  responseRef String?             @map("response_ref") @db.VarChar(255) // contractId / txHash if applicable
  status      AurigraphCallStatus @default(PENDING)
  errorCode   String?             @map("error_code") @db.VarChar(64)
  errorMsg    String?             @map("error_msg") @db.Text
  latencyMs   Int?                @map("latency_ms")
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([method, createdAt])
  @@index([status])
  @@map("aurigraph_call_logs")
}

// ─── Biocarbon Sprint 2 — Aurigraph events worker (AAT-ζ / AV4-375) ────────
// Async side of the lock-then-mint loop. The Aurigraph events worker
// (apps/api/src/workers/aurigraph-events.worker.ts) polls the Aurigraph
// public ledger for burn / retire / delist events on UC_CARBON contracts
// owned by Aurex, classifies them via metadata, and forwards the action
// to the BCR adapter (retireVCC for retirement burns, unlockVCC for delist
// burns).
//
// Two singleton-ish models support that loop:
//
//   - AurigraphEventCursor (id="default" row) — last-processed pointer so
//     restarts don't re-replay the entire ledger.
//   - AurigraphProcessedEvent (txHash PK) — per-event idempotency guard +
//     retry counter + permanent-failure marker for dead-letter handling.

enum AurigraphEventType {
  BURN_FOR_RETIREMENT @map("burn_for_retirement")
  BURN_FOR_DELIST     @map("burn_for_delist")
}

enum AurigraphProcessedEventStatus {
  PENDING          @map("pending")
  PROCESSED        @map("processed")
  FAILED_PERMANENT @map("failed_permanent")
}

/// Singleton-row cursor tracking the last burn/retire/delist event the
/// worker has consumed from Aurigraph's public ledger. Always queried by
/// id = "default".
model AurigraphEventCursor {
  id              String   @id @db.VarChar(64) // sentinel "default" row
  lastTxHash      String?  @map("last_tx_hash") @db.VarChar(255)
  lastProcessedAt DateTime? @map("last_processed_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("aurigraph_event_cursors")
}

/// One row per Aurigraph burn/retire/delist tx the worker has seen.
/// `txHash` is the natural primary key — re-processing the same tx is a
/// no-op. `retryCount` tracks at-least-once delivery to the BCR adapter;
/// after exceeding the operator-configured limit the row flips to
/// FAILED_PERMANENT and the worker advances the cursor past it for human
/// review (alert log emitted).
model AurigraphProcessedEvent {
  txHash      String                        @id @map("tx_hash") @db.VarChar(255)
  eventType   AurigraphEventType            @map("event_type")
  issuanceId  String?                       @map("issuance_id") @db.Uuid
  retryCount  Int                           @default(0) @map("retry_count")
  status      AurigraphProcessedEventStatus @default(PENDING)
  lastError   String?                       @map("last_error") @db.Text
  createdAt   DateTime                      @default(now()) @map("created_at")
  updatedAt   DateTime                      @updatedAt @map("updated_at")

  issuance Issuance? @relation(fields: [issuanceId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([issuanceId])
  @@map("aurigraph_processed_events")
}
