generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity & Auth (ADM-052/055 WBS 3.x) ───

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique @db.VarChar(254)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  name           String    @db.VarChar(200)
  role           Role      @default(VIEWER)
  isActive       Boolean   @default(true) @map("is_active")
  isVerified     Boolean   @default(false) @map("is_verified")
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret") @db.VarChar(255)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip") @db.VarChar(45)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  sessions         Session[]
  authEvents       AuthEvent[]
  orgMembers       OrgMember[]
  emissionsCreated EmissionsRecord[] @relation("emissionsCreator")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token") @db.VarChar(512)
  userAgent    String?  @map("user_agent") @db.VarChar(512)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthEvent {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  eventType AuthEventType @map("event_type")
  ipAddress String?       @map("ip_address") @db.VarChar(45)
  userAgent String?       @map("user_agent") @db.VarChar(512)
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("auth_events")
}

// ─── Multi-tenant Organizations (WBS 2.1.3) ───

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members          OrgMember[]
  emissionsRecords EmissionsRecord[]
  baselines        EmissionsBaseline[]
  targets          EmissionsTarget[]

  @@map("organizations")
}

model OrgMember {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  orgId     String  @map("org_id") @db.Uuid
  role      Role    @default(VIEWER)
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_members")
}

// ─── Emissions Data (WBS 2.3, 2.4) ───

enum EmissionStatus {
  DRAFT    @map("draft")
  PENDING  @map("pending")
  VERIFIED @map("verified")
  REJECTED @map("rejected")
}

model EmissionsRecord {
  id          String         @id @default(uuid()) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  scope       EmissionScope
  category    String         @db.VarChar(100)
  source      String         @db.VarChar(255)
  value       Decimal        @db.Decimal(15, 4)
  unit        String         @default("tCO2e") @db.VarChar(20)
  periodStart DateTime       @map("period_start")
  periodEnd   DateTime       @map("period_end")
  status      EmissionStatus @default(DRAFT)
  metadata    Json?
  createdBy   String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation("emissionsCreator", fields: [createdBy], references: [id])

  @@index([orgId, scope])
  @@index([orgId, status])
  @@index([periodStart, periodEnd])
  @@map("emissions_records")
}

model EmissionSource {
  id       String        @id @default(uuid()) @db.Uuid
  scope    EmissionScope
  category String        @db.VarChar(100)
  name     String        @db.VarChar(255)
  isActive Boolean       @default(true) @map("is_active")

  @@unique([scope, category, name])
  @@map("emission_sources")
}

model EmissionFactor {
  id         String        @id @default(uuid()) @db.Uuid
  scope      EmissionScope
  category   String        @db.VarChar(100)
  source     String        @db.VarChar(255)
  factor     Decimal       @db.Decimal(15, 8)
  unit       String        @db.VarChar(50)
  region     String?       @db.VarChar(100)
  year       Int?
  dataSource String?       @map("data_source") @db.VarChar(255)

  @@map("emission_factors")
}

model EmissionsBaseline {
  id          String        @id @default(uuid()) @db.Uuid
  orgId       String        @map("org_id") @db.Uuid
  name        String        @db.VarChar(255)
  scope       EmissionScope
  baseYear    Int           @map("base_year")
  value       Decimal       @db.Decimal(15, 4)
  unit        String        @default("tCO2e") @db.VarChar(20)
  methodology String?       @db.VarChar(255)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("emissions_baselines")
}

model EmissionsTarget {
  id          String        @id @default(uuid()) @db.Uuid
  orgId       String        @map("org_id") @db.Uuid
  name        String        @db.VarChar(255)
  scope       EmissionScope
  targetYear  Int           @map("target_year")
  reduction   Decimal       @db.Decimal(5, 2) // percentage
  pathway     SBTiPathway?
  isApproved  Boolean       @default(false) @map("is_approved")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  org      Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  progress TargetProgress[]

  @@index([orgId])
  @@map("emissions_targets")
}

model TargetProgress {
  id        String   @id @default(uuid()) @db.Uuid
  targetId  String   @map("target_id") @db.Uuid
  year      Int
  actual    Decimal  @db.Decimal(15, 4)
  projected Decimal? @db.Decimal(15, 4)
  variance  Decimal? @db.Decimal(8, 4)
  createdAt DateTime @default(now()) @map("created_at")

  target EmissionsTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, year])
  @@map("target_progress")
}

// ─── Audit Log (ADM-056/057) ───

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?  @map("resource_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Enums ───

enum Role {
  SUPER_ADMIN @map("super_admin")
  ORG_ADMIN   @map("org_admin")
  MANAGER     @map("manager")
  ANALYST     @map("analyst")
  VIEWER      @map("viewer")
}

enum AuthEventType {
  LOGIN_SUCCESS   @map("login_success")
  LOGIN_FAILURE   @map("login_failure")
  LOGOUT          @map("logout")
  TOKEN_REFRESH   @map("token_refresh")
  PASSWORD_CHANGE @map("password_change")
  MFA_ENABLED     @map("mfa_enabled")
  MFA_DISABLED    @map("mfa_disabled")
  ACCOUNT_LOCKED  @map("account_locked")
  ACCOUNT_UNLOCK  @map("account_unlock")
}

enum EmissionScope {
  SCOPE_1 @map("scope_1")
  SCOPE_2 @map("scope_2")
  SCOPE_3 @map("scope_3")
}

enum SBTiPathway {
  CELSIUS_1_5 @map("1.5C")
  WELL_BELOW_2 @map("WB2C")
  CELSIUS_2   @map("2C")
}
