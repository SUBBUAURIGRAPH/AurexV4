generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Identity & Auth (ADM-052/055 WBS 3.x) ───

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique @db.VarChar(254)
  passwordHash   String    @map("password_hash") @db.VarChar(255)
  name           String    @db.VarChar(200)
  role           Role      @default(VIEWER)
  isActive       Boolean   @default(true) @map("is_active")
  isVerified     Boolean   @default(false) @map("is_verified")
  mfaEnabled     Boolean   @default(false) @map("mfa_enabled")
  mfaSecret      String?   @map("mfa_secret") @db.VarChar(255)
  failedAttempts Int       @default(0) @map("failed_attempts")
  lockedUntil    DateTime? @map("locked_until")
  lastLoginAt    DateTime? @map("last_login_at")
  lastLoginIp    String?   @map("last_login_ip") @db.VarChar(45)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  sessions           Session[]
  authEvents         AuthEvent[]
  orgMembers         OrgMember[]
  emissionsCreated   EmissionsRecord[] @relation("emissionsCreator")
  reportsCreated     Report[]          @relation("reportsCreator")
  reportsApproved    Report[]          @relation("reportsApprover")
  reportsPublished   Report[]          @relation("reportsPublisher")
  reportsArchived    Report[]          @relation("reportsArchiver")
  importJobsCreated  ImportJob[]       @relation("importJobsCreator")
  notifications      Notification[]          @relation("notifications")
  notificationPrefs  NotificationPreference? @relation("notificationPrefs")
  approvalRequests   ApprovalRequest[] @relation("approvalRequests")
  approvalDecisions  ApprovalRequest[] @relation("approvalDecisions")
  approvalComments   ApprovalComment[]
  approvalVotes      ApprovalVote[]    @relation("approvalVotes")
  workflowEnablements OrgWorkflowEnablement[] @relation("workflowEnabler")
  brsrResponses      BrsrResponse[]    @relation("brsrResponsesCreator")

  @@index([email])
  @@index([role])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  refreshToken String   @unique @map("refresh_token") @db.VarChar(512)
  userAgent    String?  @map("user_agent") @db.VarChar(512)
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model AuthEvent {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @map("user_id") @db.Uuid
  eventType AuthEventType @map("event_type")
  ipAddress String?       @map("ip_address") @db.VarChar(45)
  userAgent String?       @map("user_agent") @db.VarChar(512)
  metadata  Json?
  createdAt DateTime      @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("auth_events")
}

// ─── Multi-tenant Organizations (WBS 2.1.3) ───

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  isActive    Boolean  @default(true) @map("is_active")
  parentOrgId String?  @map("parent_org_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Organization?  @relation("OrgHierarchy", fields: [parentOrgId], references: [id], onDelete: SetNull)
  children Organization[] @relation("OrgHierarchy")

  members           OrgMember[]
  emissionsRecords  EmissionsRecord[]
  baselines         EmissionsBaseline[]
  targets           EmissionsTarget[]
  reports           Report[]
  importJobs        ImportJob[]
  notifications      Notification[]
  approvals          ApprovalRequest[]
  frameworkMappings  OrgFrameworkMapping[]
  brsrResponses      BrsrResponse[]
  onboardingProgress OnboardingProgress?
  suppliers          Supplier[]
  supplierRequests   SupplierDataRequest[]
  categoryMappings   CategoryMapping[]
  workflowEnablements OrgWorkflowEnablement[]

  // A6.4 (Paris Agreement Crediting Mechanism) back-relations
  activities         Activity[]
  creditAccounts     CreditAccount[]

  @@index([parentOrgId])
  @@map("organizations")
}

model OrgMember {
  id        String  @id @default(uuid()) @db.Uuid
  userId    String  @map("user_id") @db.Uuid
  orgId     String  @map("org_id") @db.Uuid
  role      Role    @default(VIEWER)
  isActive  Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("org_members")
}

// ─── Emissions Data (WBS 2.3, 2.4) ───

enum EmissionStatus {
  DRAFT    @map("draft")
  PENDING  @map("pending")
  VERIFIED @map("verified")
  REJECTED @map("rejected")
}

model EmissionsRecord {
  id          String         @id @default(uuid()) @db.Uuid
  orgId       String         @map("org_id") @db.Uuid
  scope       EmissionScope
  category    String         @db.VarChar(100)
  source      String         @db.VarChar(255)
  value       Decimal        @db.Decimal(15, 4)
  unit        String         @default("tCO2e") @db.VarChar(20)
  periodStart DateTime       @map("period_start")
  periodEnd   DateTime       @map("period_end")
  status      EmissionStatus @default(DRAFT)
  metadata    Json?
  createdBy   String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation("emissionsCreator", fields: [createdBy], references: [id])

  @@index([orgId, scope])
  @@index([orgId, status])
  @@index([periodStart, periodEnd])
  @@map("emissions_records")
}

model EmissionSource {
  id       String        @id @default(uuid()) @db.Uuid
  scope    EmissionScope
  category String        @db.VarChar(100)
  name     String        @db.VarChar(255)
  isActive Boolean       @default(true) @map("is_active")

  @@unique([scope, category, name])
  @@map("emission_sources")
}

model EmissionFactor {
  id         String        @id @default(uuid()) @db.Uuid
  scope      EmissionScope
  category   String        @db.VarChar(100)
  source     String        @db.VarChar(255)
  factor     Decimal       @db.Decimal(15, 8)
  unit       String        @db.VarChar(50)
  region     String?       @db.VarChar(100)
  year       Int?
  dataSource String?       @map("data_source") @db.VarChar(255)

  @@map("emission_factors")
}

/// Maps emission category (free-text on EmissionsRecord) to framework indicator
/// codes. Reports roll up an emissions record into an indicator by looking up
/// the mapping for that (scope, category) and, if `orgId` is set, preferring
/// the org override over the platform default.
model CategoryMapping {
  id                   String        @id @default(uuid()) @db.Uuid
  orgId                String?       @map("org_id") @db.Uuid
  scope                EmissionScope
  category             String        @db.VarChar(100)
  esgIndicatorCodes    String[]      @map("esg_indicator_codes")
  brsrIndicatorCodes   String[]      @map("brsr_indicator_codes")
  isDefault            Boolean       @default(false) @map("is_default")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  org Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, scope, category])
  @@index([scope, category])
  @@map("category_mappings")
}

model EmissionsBaseline {
  id          String        @id @default(uuid()) @db.Uuid
  orgId       String        @map("org_id") @db.Uuid
  name        String        @db.VarChar(255)
  scope       EmissionScope
  baseYear    Int           @map("base_year")
  value       Decimal       @db.Decimal(15, 4)
  unit        String        @default("tCO2e") @db.VarChar(20)
  methodology String?       @db.VarChar(255)
  isActive    Boolean       @default(true) @map("is_active")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@map("emissions_baselines")
}

model EmissionsTarget {
  id          String        @id @default(uuid()) @db.Uuid
  orgId       String        @map("org_id") @db.Uuid
  name        String        @db.VarChar(255)
  scope       EmissionScope
  targetYear  Int           @map("target_year")
  reduction   Decimal       @db.Decimal(5, 2) // percentage
  pathway     SBTiPathway?
  isApproved  Boolean       @default(false) @map("is_approved")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  org      Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  progress TargetProgress[]

  @@index([orgId])
  @@map("emissions_targets")
}

model TargetProgress {
  id        String   @id @default(uuid()) @db.Uuid
  targetId  String   @map("target_id") @db.Uuid
  year      Int
  actual    Decimal  @db.Decimal(15, 4)
  projected Decimal? @db.Decimal(15, 4)
  variance  Decimal? @db.Decimal(8, 4)
  createdAt DateTime @default(now()) @map("created_at")

  target EmissionsTarget @relation(fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([targetId, year])
  @@map("target_progress")
}

// ─── Reports (AAT-2) ───

enum ReportLifecycleStatus {
  DRAFT     @map("draft")
  REVIEW    @map("review")
  APPROVED  @map("approved")
  PUBLISHED @map("published")
  ARCHIVED  @map("archived")
}

model Report {
  id              String                @id @default(uuid()) @db.Uuid
  orgId           String                @map("org_id") @db.Uuid
  type            String                @db.VarChar(50)
  status          String                @default("QUEUED") @db.VarChar(20)
  lifecycleStatus ReportLifecycleStatus @default(DRAFT) @map("lifecycle_status")
  parameters      Json?
  reportData      Json?                 @map("report_data")
  createdBy       String                @map("created_by") @db.Uuid
  submittedAt     DateTime?             @map("submitted_at")
  approvedAt      DateTime?             @map("approved_at")
  approvedBy      String?               @map("approved_by") @db.Uuid
  publishedAt     DateTime?             @map("published_at")
  publishedBy     String?               @map("published_by") @db.Uuid
  archivedAt      DateTime?             @map("archived_at")
  archivedBy      String?               @map("archived_by") @db.Uuid
  shareToken      String?               @unique @map("share_token") @db.VarChar(100)
  createdAt       DateTime              @default(now()) @map("created_at")
  updatedAt       DateTime              @updatedAt @map("updated_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation("reportsCreator", fields: [createdBy], references: [id])
  approver  User?        @relation("reportsApprover", fields: [approvedBy], references: [id])
  publisher User?        @relation("reportsPublisher", fields: [publishedBy], references: [id])
  archiver  User?        @relation("reportsArchiver", fields: [archivedBy], references: [id])

  @@index([orgId])
  @@index([orgId, lifecycleStatus])
  @@map("reports")
}

// ─── Import Jobs (AV4-255 — CSV bulk import) ───

enum ImportJobStatus {
  QUEUED     @map("queued")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
}

model ImportJob {
  id             String          @id @default(uuid()) @db.Uuid
  orgId          String          @map("org_id") @db.Uuid
  createdBy      String          @map("created_by") @db.Uuid
  filename       String          @db.VarChar(255)
  status         ImportJobStatus @default(QUEUED)
  totalRows      Int             @default(0) @map("total_rows")
  processedRows  Int             @default(0) @map("processed_rows")
  successRows    Int             @default(0) @map("success_rows")
  errorRows      Int             @default(0) @map("error_rows")
  errors         Json?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation("importJobsCreator", fields: [createdBy], references: [id])

  @@index([orgId])
  @@map("import_jobs")
}

// ─── Audit Log (ADM-056/057) ───

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  orgId      String?  @map("org_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?  @map("resource_id") @db.Uuid
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([orgId])
  @@index([userId])
  @@index([resource, resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Enums ───

enum Role {
  SUPER_ADMIN @map("super_admin")
  ORG_ADMIN   @map("org_admin")
  MANAGER     @map("manager")
  ANALYST     @map("analyst")
  VIEWER      @map("viewer")
  MAKER       @map("maker")
  CHECKER     @map("checker")
  APPROVER    @map("approver")
  AUDITOR     @map("auditor")
  // A6.4 / PACM actors (ADM-060 gap-analysis addition)
  DOE         @map("doe")          // Designated Operational Entity (third-party validator/verifier)
  DNA         @map("dna")          // Designated National Authority (host-country approver)
  SB_OBSERVER @map("sb_observer")  // Supervisory Body observer (read-only registry view)
}

enum AuthEventType {
  LOGIN_SUCCESS   @map("login_success")
  LOGIN_FAILURE   @map("login_failure")
  LOGOUT          @map("logout")
  TOKEN_REFRESH   @map("token_refresh")
  PASSWORD_CHANGE @map("password_change")
  MFA_ENABLED     @map("mfa_enabled")
  MFA_DISABLED    @map("mfa_disabled")
  ACCOUNT_LOCKED  @map("account_locked")
  ACCOUNT_UNLOCK  @map("account_unlock")
}

enum EmissionScope {
  SCOPE_1 @map("scope_1")
  SCOPE_2 @map("scope_2")
  SCOPE_3 @map("scope_3")
}

enum SBTiPathway {
  CELSIUS_1_5 @map("1.5C")
  WELL_BELOW_2 @map("WB2C")
  CELSIUS_2   @map("2C")
}

// ─── Notifications (AV4-264 — polling-based) ───

enum NotificationType {
  INFO    @map("info")
  WARNING @map("warning")
  SUCCESS @map("success")
  ERROR   @map("error")
}

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  orgId      String?          @map("org_id") @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  type       NotificationType @default(INFO)
  title      String           @db.VarChar(255)
  body       String?          @db.Text
  resource   String?          @db.VarChar(100)
  resourceId String?          @map("resource_id") @db.Uuid
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")

  user User          @relation("notifications", fields: [userId], references: [id], onDelete: Cascade)
  org  Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([orgId])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                     String   @id @default(uuid()) @db.Uuid
  userId                 String   @unique @map("user_id") @db.Uuid
  emailOnStatusChange    Boolean  @default(true) @map("email_on_status_change")
  emailOnApprovalRequest Boolean  @default(true) @map("email_on_approval_request")
  inAppOnStatusChange    Boolean  @default(true) @map("in_app_on_status_change")
  inAppOnApprovalRequest Boolean  @default(true) @map("in_app_on_approval_request")
  updatedAt              DateTime @updatedAt @map("updated_at")

  user User @relation("notificationPrefs", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── Approval Workflow (AV4-219) ───

enum ApprovalStatus {
  PENDING   @map("pending")
  APPROVED  @map("approved")
  REJECTED  @map("rejected")
  CANCELLED @map("cancelled")
}

model ApprovalRequest {
  id                String          @id @default(uuid()) @db.Uuid
  orgId             String          @map("org_id") @db.Uuid
  resource          String          @db.VarChar(100)
  resourceId        String          @map("resource_id") @db.Uuid
  requestedBy       String          @map("requested_by") @db.Uuid
  status            ApprovalStatus  @default(PENDING)
  decidedBy         String?         @map("decided_by") @db.Uuid
  decidedAt         DateTime?       @map("decided_at")
  reason            String?         @db.Text
  payload           Json?
  recipeId          String?         @map("recipe_id") @db.Uuid
  requiredApprovers Int             @default(1) @map("required_approvers")
  approvalsReceived Int             @default(0) @map("approvals_received")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  org       Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  requester User              @relation("approvalRequests", fields: [requestedBy], references: [id])
  decider   User?             @relation("approvalDecisions", fields: [decidedBy], references: [id])
  comments  ApprovalComment[]
  votes     ApprovalVote[]

  @@index([orgId, status])
  @@index([resource, resourceId])
  @@map("approval_requests")
}

model ApprovalComment {
  id         String   @id @default(uuid()) @db.Uuid
  requestId  String   @map("request_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  body       String   @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id])

  @@index([requestId])
  @@map("approval_comments")
}

// ─── Configurable Approval Recipes (Phase C) ───

model WorkflowRecipe {
  id                String   @id @default(uuid()) @db.Uuid
  code              String   @unique @db.VarChar(50)
  name              String   @db.VarChar(100)
  description       String?  @db.Text
  requiredApprovers Int      @map("required_approvers")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  orgEnablements OrgWorkflowEnablement[]

  @@map("workflow_recipes")
}

model OrgWorkflowEnablement {
  id           String   @id @default(uuid()) @db.Uuid
  orgId        String   @map("org_id") @db.Uuid
  resourceType String   @map("resource_type") @db.VarChar(50)
  recipeId     String   @map("recipe_id") @db.Uuid
  enabledAt    DateTime @default(now()) @map("enabled_at")
  enabledBy    String   @map("enabled_by") @db.Uuid

  org     Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  recipe  WorkflowRecipe @relation(fields: [recipeId], references: [id])
  enabler User           @relation("workflowEnabler", fields: [enabledBy], references: [id])

  @@unique([orgId, resourceType])
  @@index([orgId])
  @@map("org_workflow_enablements")
}

model ApprovalVote {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @map("request_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  decision  String   @db.VarChar(20)
  reason    String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  request ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User            @relation("approvalVotes", fields: [userId], references: [id])

  @@unique([requestId, userId])
  @@index([requestId])
  @@map("approval_votes")
}

// ─── ESG Frameworks (AV4-211) ───

model EsgFramework {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(100)
  description String?  @db.Text
  version     String?  @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  indicators  EsgIndicator[]
  orgMappings OrgFrameworkMapping[]

  @@map("esg_frameworks")
}

model EsgIndicator {
  id          String   @id @default(uuid()) @db.Uuid
  frameworkId String   @map("framework_id") @db.Uuid
  code        String   @db.VarChar(50)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  category    String?  @db.VarChar(100)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  framework EsgFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)

  @@unique([frameworkId, code])
  @@index([frameworkId])
  @@map("esg_indicators")
}

model OrgFrameworkMapping {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  frameworkId String   @map("framework_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  framework EsgFramework @relation(fields: [frameworkId], references: [id])

  @@unique([orgId, frameworkId])
  @@index([orgId])
  @@map("org_framework_mappings")
}

// ─── BRSR Indicators (AV4-216) ───

enum BrsrSection {
  SECTION_A @map("section_a")
  SECTION_B @map("section_b")
  SECTION_C @map("section_c")
}

enum BrsrIndicatorType {
  ESSENTIAL  @map("essential")
  LEADERSHIP @map("leadership")
}

model BrsrPrinciple {
  id          String   @id @default(uuid()) @db.Uuid
  number      Int      @unique
  title       String   @db.VarChar(200)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  indicators BrsrIndicator[]

  @@map("brsr_principles")
}

model BrsrIndicator {
  id            String            @id @default(uuid()) @db.Uuid
  principleId   String?           @map("principle_id") @db.Uuid
  section       BrsrSection
  indicatorType BrsrIndicatorType @map("indicator_type")
  code          String            @unique @db.VarChar(30)
  title         String            @db.VarChar(300)
  description   String?           @db.Text
  isActive      Boolean           @default(true) @map("is_active")
  createdAt     DateTime          @default(now()) @map("created_at")

  principle BrsrPrinciple? @relation(fields: [principleId], references: [id])
  responses BrsrResponse[]

  @@index([principleId])
  @@index([section])
  @@map("brsr_indicators")
}

model BrsrResponse {
  id          String   @id @default(uuid()) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  indicatorId String   @map("indicator_id") @db.Uuid
  fiscalYear  String   @map("fiscal_year") @db.VarChar(10)
  value       Json
  notes       String?  @db.Text
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
