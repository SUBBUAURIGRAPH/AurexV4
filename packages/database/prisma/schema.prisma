  submittedAt   DateTime? @map("submitted_at")
  submittedBy   String?   @map("submitted_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("pdds")
}

/// Letter of Authorization (LoA) from host-country DNA.
/// Authorization granularity per Article 6.4 is activity-level.
model HostAuthorization {
  id               String   @id @default(uuid()) @db.Uuid
  activityId       String   @unique @map("activity_id") @db.Uuid
  hostCountry      String   @map("host_country") @db.VarChar(2)
