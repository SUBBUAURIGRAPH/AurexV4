}

enum AuthorizationScope {
  NDC_USE   @map("ndc_use")      // authorized for buyer NDC (→ CA applies on first transfer)
  OIMP      @map("oimp")         // Other International Mitigation Purposes (e.g. CORSIA)
  NDC_AND_OIMP @map("ndc_and_oimp")
  MITIGATION_CONTRIBUTION @map("mitigation_contribution") // A6.4ER_MC — no international transfer, no CA
}

enum HostAuthorizationStatus {
  PENDING   @map("pending")
  ISSUED    @map("issued")
  REVOKED   @map("revoked")    // only valid pre-first-transfer
  EXPIRED   @map("expired")
}

/// DOE validation of a PDD — ex-ante check that the activity meets A6.4 rules.
model ValidationReport {
  id             String   @id @default(uuid()) @db.Uuid
  activityId     String   @unique @map("activity_id") @db.Uuid
  doeUserId      String   @map("doe_user_id") @db.Uuid
  doeOrgName     String   @map("doe_org_name") @db.VarChar(255)
  doeAccreditationId String? @map("doe_accreditation_id") @db.VarChar(100)
