  authorizedFor    AuthorizationScope @map("authorized_for")
  authorizationScopeNotes String? @map("authorization_scope_notes") @db.Text
  status           HostAuthorizationStatus @default(PENDING)
  issuedAt         DateTime? @map("issued_at")
  issuedBy         String?   @map("issued_by") @db.Uuid // the DNA user id who signed
  documentUrl      String?   @map("document_url") @db.VarChar(500)
  validFrom        DateTime? @map("valid_from")
  validUntil       DateTime? @map("valid_until")
  revokedAt        DateTime? @map("revoked_at")
  revokedReason    String?   @map("revoked_reason") @db.Text
