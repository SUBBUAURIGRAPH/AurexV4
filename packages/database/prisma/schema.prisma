  findings       Json?    // structured findings list
  documentUrl    String?  @map("document_url") @db.VarChar(500)
  validatedAt    DateTime @map("validated_at")
  createdAt      DateTime @default(now()) @map("created_at")

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@map("validation_reports")
}

enum DoeOpinion {
  POSITIVE     @map("positive")
  NEGATIVE     @map("negative")
  CONDITIONAL  @map("conditional")
}

/// Monitoring plan — one per activity.
model MonitoringPlan {
  id          String   @id @default(uuid()) @db.Uuid
  activityId  String   @unique @map("activity_id") @db.Uuid
  version     Int      @default(1)
  qaqcNotes   String?  @map("qaqc_notes") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  activity   Activity              @relation(fields: [activityId], references: [id], onDelete: Cascade)
