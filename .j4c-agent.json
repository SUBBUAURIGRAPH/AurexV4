{
  "project": "AurexV4",
  "jira_project_key": "AV4",
  "jira_site": "aurigraphdlt.atlassian.net",
  "server": {
    "host": "aurex.in",
    "ssh_port": 2244,
    "user": "subbu",
    "deploy_path": "/home/subbu/aurexv4-src"
  },
  "health_endpoints": [
    {"url": "https://aurex.in/api/v1/health", "expect": 200},
    {"url": "https://aurex.in/", "expect": 200},
    {"url": "https://aurex.in/login", "expect": 200},
    {"url": "https://aurex.in/pricing", "expect": 200}
  ],
  "expected_containers": [
    "aurex-api",
    "aurex-nginx",
    "aurex-postgres",
    "aurex-redis"
  ],
  "csp_required_origins": ["'self'"],
  "autoheal": {
    "layer1_compose_file": "infrastructure/docker/docker-compose.yml",
    "layer2_systemd_unit": "aurex-watchdog.timer",
    "layer3_extprobe_unit": "aurex-external-probe.timer"
  },
  "j4c_central": {
    "grpc_endpoint": null,
    "grpc_tls": true,
    "grpc_auth_token_env": "J4C_AGENT_TOKEN",
    "comment": "AurexV4 production. grpc_endpoint stays null until the central J4C AgentReportService is live; doctor mode (local-only) is sufficient for the off-host watchdog."
  }
}
