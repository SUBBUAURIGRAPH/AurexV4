# HMS GNN Prediction System - Environment Configuration Template
# Copy this file to .env and update with your production values

# ==================== SERVER CONFIGURATION ====================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ==================== DATABASE CONFIGURATION ====================
DATABASE_URL=postgresql://postgres:password@postgres:5432/hms_trading
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_HOST=postgres
DB_PORT=5432
DB_NAME=hms_trading

# ==================== CACHE CONFIGURATION ====================
REDIS_URL=redis://redis:6379/0
CACHE_TTL=3600000
CACHE_MAX_SIZE=1000

# ==================== GNN CONFIGURATION ====================
CORRELATION_THRESHOLD=0.5
MAX_NEIGHBORS=10
BATCH_SIZE=10
PREDICTION_BATCH_ENABLED=true
LAZY_LOADING_ENABLED=true
SPARSE_MATRIX_ENABLED=true

# ==================== API CONFIGURATION ====================
API_KEY=your_api_key_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h
API_RATE_LIMIT=100
API_TIMEOUT=10000

# ==================== MONITORING & LOGGING ====================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_PASSWORD=admin_password
GRAFANA_PORT=3001
LOG_FORMAT=json
LOG_TO_FILE=true
LOG_FILE_PATH=/app/logs/app.log

# ==================== DEPLOYMENT ====================
DOCKER_REGISTRY=docker.io
APP_VERSION=1.0.0
ENVIRONMENT=production

# ==================== SECURITY ====================
ENABLE_HTTPS=true
SSL_CERT_PATH=/etc/ssl/certs/server.crt
SSL_KEY_PATH=/etc/ssl/private/server.key
CORS_ORIGIN=https://app.hms-trading.com
CORS_CREDENTIALS=true

# Initial Admin User Setup (Optional)
# SECURITY: Only set these if you need to create an initial admin user
# Leave empty to prevent automatic user creation
INITIAL_ADMIN_USERNAME=
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Input Validation & Rate Limiting
MAX_REQUEST_SIZE=10mb
MAX_QUERY_DEPTH=10
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
API_TIMEOUT_MS=10000
ENABLE_INPUT_VALIDATION=true
ENABLE_SQL_INJECTION_PROTECTION=true
ENABLE_XSS_PROTECTION=true

# ==================== MOBILE APP ====================
MOBILE_API_URL=https://api.hms-trading.com
MOBILE_API_TIMEOUT=10000
MOBILE_ENABLE_LOGS=true

# ==================== FEATURE FLAGS ====================
ENABLE_ALERTS=true
ENABLE_WATCHLIST=true
ENABLE_BACKTESTING=true
ENABLE_EXPORT=true
ENABLE_REALTIME_PREDICTIONS=true

# ==================== EXTERNAL SERVICES ====================
# Add your external API keys here
ALPHA_VANTAGE_API_KEY=your_key_here
IEX_API_KEY=your_key_here
FINNHUB_API_KEY=your_key_here

# ==================== BACKUP & RECOVERY ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
