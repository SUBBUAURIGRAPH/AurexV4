# J4C Agent Plugin - Docker Dockerfile
# Version: 1.0.0
# Build: docker build -f Dockerfile.j4c -t aurigraph/j4c-agent:1.0.0 .

FROM node:18-alpine as builder

# Install build dependencies
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git

WORKDIR /build

# Copy package files
COPY plugin/package*.json ./

# Install dependencies
RUN npm ci --production && npm ci

COPY plugin/ ./

# Run validation
RUN npm run validate || true

# ===== Production Stage =====
FROM node:18-alpine

# Install runtime dependencies
RUN apk add --no-cache \
    curl \
    ca-certificates \
    tini

# Create non-root user
RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001

WORKDIR /app

# Copy from builder
COPY --from=builder --chown=nodejs:nodejs /build /app

# Set environment
ENV NODE_ENV=production \
    PORT=9003 \
    LOG_LEVEL=info

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=10s --retries=3 \
    CMD curl -f http://localhost:9003/health || exit 1

# Switch to non-root user
USER nodejs

# Expose ports
EXPOSE 9003

# Entry point
ENTRYPOINT ["/sbin/tini", "--"]

# Start application
CMD ["node", "index.js"]

# Labels
LABEL maintainer="Aurigraph Development Team <engineering@aurigraph.io>" \
      version="1.0.0" \
      description="J4C Agent Plugin with HubSpot and Claude Code integration" \
      org.opencontainers.image.source="https://github.com/Aurigraph-DLT-Corp/glowing-adventure"
