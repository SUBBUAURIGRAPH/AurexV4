{
  "name": "hms-trading-platform",
  "version": "2.0.0",
  "description": "Hermes Trading Platform - AI-Powered Trading System with Phase 3 Part 2 Backend",
  "main": "backend/src/server.ts",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:web\" 2>/dev/null || npm run dev:backend",
    "dev:backend": "cd backend && npm run dev 2>/dev/null || node src/server.ts",
    "dev:web": "cd web && npm run dev 2>/dev/null || echo 'Web dev requires vite setup'",
    "build": "npm run build:backend && npm run build:web",
    "build:backend": "cd backend && npm run build 2>/dev/null || tsc",
    "build:web": "cd web && npm run build 2>/dev/null || echo 'Web build requires vite setup'",
    "start": "node backend/src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:exchange": "jest --testNamePattern='exchange-connector|ExchangeConnector'",
    "test:integration": "jest --testNamePattern='integration|Integration'",
    "test:backend": "cd backend && npm run test 2>/dev/null || jest",
    "lint": "eslint . --ext .ts,.tsx 2>/dev/null || echo 'ESLint not configured'",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" 2>/dev/null || echo 'Prettier not configured'",
    "docker:build": "docker build -t hms-gnn:latest -f Dockerfile .",
    "docker:run": "docker run -p 3000:3000 -e NODE_ENV=production hms-gnn:latest",
    "deploy": "bash deploy-hms-v2.sh"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "pg": "^8.11.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.9.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "ts-jest": "^29.4.5",
    "typescript": "^5.2.2"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Aurigraph-DLT-Corp/glowing-adventure.git"
  },
  "author": "Aurigraph DLT Corp",
  "license": "MIT"
}
