# AurexV4 Environment Configuration
# Copy to .env and fill in values — NEVER commit .env

# Database (ADM-052: no hardcoded credentials)
DB_USER=aurex
DB_PASSWORD=
DB_NAME=aurexv4
DATABASE_URL=postgresql://aurex:PASSWORD@localhost:5432/aurexv4
DIRECT_URL=postgresql://aurex:PASSWORD@localhost:5432/aurexv4

# Redis
REDIS_PASSWORD=
REDIS_URL=redis://:PASSWORD@localhost:6379

# Auth (ADM-052: JWT RS256)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS (ADM-041: CSRF redundant with CORS + JWT + SameSite)
CORS_ORIGINS=https://aurex.in,https://www.aurex.in

# Google Sign-In (Server-side OAuth 2.0 / Authorization Code flow).
# Leave empty to disable — /api/v1/auth/google/* returns 503.
# Register the redirect URI EXACTLY as below in Google Cloud Console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://aurex.in/api/v1/auth/google/callback
WEB_BASE_URL=https://aurex.in

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@aurex.in

# SSL/TLS (ADM-054)
SSL_CERT_PATH=/etc/letsencrypt/live/aurex.in/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/aurex.in/privkey.pem

# Deployment (aurex.in production host)
DEPLOY_HOST=aurex.in
DEPLOY_USER=subbu
DEPLOY_SSH_PORT=2244
DEPLOY_WEB_PATH=/home/subbu/aurex/web
DEPLOY_SRC_PATH=/home/subbu/aurexv4-src
API_CONTAINER=aurex-api
API_IMAGE=aurexv4-api
# Set to 1 when Prisma schema changed and needs db push
RUN_DB_PUSH=0

# OpenBao (J4C KMS) / Vault-API (WBS 11.1.1) — optional; omit in local dev
# J4C: OpenBao = secrets/KMS; Harbor = Docker registry (see credentials.example.md).
# Harbor UI/API base: https://j4c.aurigraph.io/harbor  (AURIGRAPH_J4C_HARBOR_BASE in j4c-platform.ts)
# If set, API pulls KV v2 secrets and merges into process.env before Prisma.
# Canonical Aurigraph J4C OpenBao base (AURIGRAPH_J4C_OPENBAO_ADDR, j4c-platform.ts / openbao-env):
# OPENBAO_ADDR=https://j4c.aurigraph.io/openbao
# OPENBAO_ADDR=https://openbao.internal:8200   # alternate: local / private host
# OPENBAO_TOKEN=                         # or VAULT_ADDR / VAULT_TOKEN
# OPENBAO_KV_MOUNT=secret
# OPENBAO_KV_DATA_PATH=aurex/api
# OPENBAO_ENABLED=0                    # 1 to force on when using AppRole, etc.
# OPENBAO_DISABLE=0                    # 1 to skip even if addr+token set
# OPENBAO_ENV_OVERRIDE=1               # 0 to not overwrite .env keys
# OPENBAO_STRICT=1                    # throw on 4xx/5xx (else warn in non-prod)
# OPENBAO_LOG_KEYS=0                   # 1 to log key names (not values) after merge
# OPENBAO_IN_TEST=0                  # 1 in Vitest to enable OpenBao (not default)

# Application
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
