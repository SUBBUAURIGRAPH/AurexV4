# Aurigraph Agents - Environment Variables
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control - it's in .gitignore for security

# ============================================
# JIRA Configuration
# ============================================
JIRA_API_KEY=your_jira_api_token_here
JIRA_EMAIL=your_email@aurigraph.io
JIRA_BASE_URL=https://aurigraph.atlassian.net

# ============================================
# GitHub Configuration
# ============================================
GITHUB_TOKEN=your_github_token_here
GITHUB_API_URL=https://api.github.com

# ============================================
# Docker Configuration
# ============================================
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_REGISTRY_USERNAME=your_registry_user
DOCKER_REGISTRY_PASSWORD=your_registry_password
DOCKER_REGISTRY_URL=docker.io

# ============================================
# Database Configuration
# ============================================
MONGODB_URI=mongodb://localhost:27017/aurigraph
MONGODB_USER=
MONGODB_PASSWORD=

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
LOG_LEVEL=info
PORT=3000

# ============================================
# AWS Configuration (Optional)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ============================================
# Slack Configuration (Optional)
# ============================================
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ============================================
# Security
# ============================================
JWT_SECRET=your_jwt_secret_key_here
ENCRYPTION_KEY=your_encryption_key_here
