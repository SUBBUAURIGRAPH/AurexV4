{
  "dashboard": {
    "title": "GNN Advanced Trading Analytics",
    "uid": "gnn-advanced-trading",
    "version": 1,
    "timezone": "UTC",
    "panels": [
      {
        "id": 1,
        "title": "Daily P&L",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "gnn_daily_pnl",
            "legendFormat": "Daily P&L"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 10 }
          }
        }
      },
      {
        "id": 2,
        "title": "Cumulative Return",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "gnn_cumulative_return",
            "legendFormat": "Cumulative Return"
          }
        ]
      },
      {
        "id": 3,
        "title": "Win Rate",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 4, "x": 0, "y": 8 },
        "targets": [
          { "expr": "gnn_win_rate" }
        ],
        "fieldConfig": {
          "defaults": {
            "min": 0,
            "max": 1,
            "unit": "percentunit",
            "custom": { "hideFrom": { "tooltip": false, "viz": false, "legend": false } }
          }
        }
      },
      {
        "id": 4,
        "title": "Profit Factor",
        "type": "stat",
        "gridPos": { "h": 6, "w": 4, "x": 4, "y": 8 },
        "targets": [
          { "expr": "gnn_profit_factor" }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1.5 }] }
          }
        }
      },
      {
        "id": 5,
        "title": "Total Trades",
        "type": "stat",
        "gridPos": { "h": 6, "w": 4, "x": 8, "y": 8 },
        "targets": [
          { "expr": "gnn_total_trades" }
        ]
      },
      {
        "id": 6,
        "title": "Sharpe Ratio",
        "type": "stat",
        "gridPos": { "h": 6, "w": 4, "x": 12, "y": 8 },
        "targets": [
          { "expr": "gnn_sharpe_ratio" }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "yellow", "value": 1 }, { "color": "green", "value": 1.5 }] }
          }
        }
      },
      {
        "id": 7,
        "title": "Volatility",
        "type": "stat",
        "gridPos": { "h": 6, "w": 4, "x": 16, "y": 8 },
        "targets": [
          { "expr": "gnn_volatility" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit" }
        }
      },
      {
        "id": 8,
        "title": "Max Drawdown",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 4, "x": 20, "y": 8 },
        "targets": [
          { "expr": "gnn_max_drawdown" }
        ],
        "fieldConfig": {
          "defaults": {
            "min": -1,
            "max": 0,
            "unit": "percentunit",
            "color": { "mode": "thresholds" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": -0.5 }, { "color": "yellow", "value": -0.2 }, { "color": "red", "value": -0.1 }] }
          }
        }
      },
      {
        "id": 9,
        "title": "Strategy Breakdown",
        "type": "piechart",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "targets": [
          { "expr": "gnn_strategy_pnl" }
        ]
      },
      {
        "id": 10,
        "title": "Instrument Performance",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "targets": [
          { "expr": "gnn_instrument_stats" }
        ]
      },
      {
        "id": 11,
        "title": "Rolling Sharpe Ratio (60-day)",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
        "targets": [
          { "expr": "gnn_rolling_sharpe_60" }
        ]
      },
      {
        "id": 12,
        "title": "Average Win / Loss",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 28 },
        "targets": [
          { "expr": "gnn_avg_win" },
          { "expr": "gnn_avg_loss" }
        ]
      },
      {
        "id": 13,
        "title": "Consecutive Metrics",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 28 },
        "targets": [
          { "expr": "gnn_max_consecutive_wins" },
          { "expr": "gnn_max_consecutive_losses" }
        ]
      },
      {
        "id": 14,
        "title": "Expectancy",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 28 },
        "targets": [
          { "expr": "gnn_expectancy" }
        ]
      },
      {
        "id": 15,
        "title": "Portfolio Value",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 28 },
        "targets": [
          { "expr": "gnn_portfolio_value" }
        ],
        "fieldConfig": {
          "defaults": { "unit": "currencyUSD" }
        }
      }
    ],
    "refresh": "1m",
    "time": { "from": "now-3M", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "period",
          "type": "custom",
          "options": ["1d", "1w", "1M", "3M", "1y"],
          "current": { "value": "3M" }
        }
      ]
    }
  }
}
