{
  "name": "odoo-mcp-integrations",
  "version": "1.0.0",
  "description": "Odoo MCP server with Zoom and HubSpot integrations",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
