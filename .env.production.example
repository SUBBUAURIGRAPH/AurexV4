# Production Environment Configuration
# Copy to .env.production and fill in actual values

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
LOG_LEVEL=info
DEBUG=false
VERSION=v2.1.0

# ============================================
# REMOTE SERVER
# ============================================
REMOTE_HOST=prod-server.example.com
REMOTE_USER=ubuntu
REMOTE_PORT=22
SSH_KEY_PATH=/home/user/.ssh/aurigraph-prod.pem

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DB_HOST=aurigraph-db.c5zxu1w2a3b4.rds.amazonaws.com
DB_PORT=5432
DB_NAME=aurigraph_production
DB_USER=aurigraph_admin
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD_MIN_8_CHARS
DB_SSL=true
DB_MAX_CONNECTIONS=50
DB_POOL_IDLE_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=30000

# ============================================
# REDIS
# ============================================
REDIS_HOST=aurigraph-redis.xxxxxx.ng.0001.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_AUTH_TOKEN_MIN_16_CHARS
REDIS_DB=0
REDIS_MAX_RETRIES=5
REDIS_CONNECT_TIMEOUT=5000

# ============================================
# EXCHANGE CONNECTOR
# ============================================
EXCHANGE_API_KEY_ENCRYPTION_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_12_CHARS
EXCHANGE_CONNECTION_POOL_SIZE=50
EXCHANGE_RATE_LIMIT_ENABLED=true
EXCHANGE_CIRCUIT_BREAKER_THRESHOLD=5
EXCHANGE_CIRCUIT_BREAKER_TIMEOUT=30000
EXCHANGE_HEALTH_CHECK_INTERVAL=60000

# ============================================
# STRATEGY BUILDER
# ============================================
STRATEGY_ENGINE_MAX_CONCURRENT=100
STRATEGY_OPTIMIZATION_MAX_ITERATIONS=500
STRATEGY_BACKTESTING_ENABLED=true
STRATEGY_CACHE_ENABLED=true
STRATEGY_CACHE_TTL=3600

# ============================================
# API
# ============================================
API_PORT=8080
API_HOST=0.0.0.0
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=60000
CORS_ORIGIN=https://app.example.com
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_JWT_SECRET_32_CHARS
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# ============================================
# ENCRYPTION
# ============================================
ENCRYPTION_ALGORITHM=aes-256-gcm
ENCRYPTION_KEY_LENGTH=32
ENCRYPTION_IV_LENGTH=16
ENCRYPTION_AUTH_TAG_LENGTH=16

# ============================================
# MONITORING & LOGGING
# ============================================
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_METRICS_PREFIX=aurigraph_
DATADOG_API_KEY=CHANGE_ME_DATADOG_API_KEY
DATADOG_ENABLED=false
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_ENABLED=true
SENTRY_TRACING_SAMPLE_RATE=0.1

# ============================================
# DOCKER REGISTRY
# ============================================
DOCKER_REGISTRY=ghcr.io
DOCKER_REGISTRY_USERNAME=github_username
DOCKER_REGISTRY_PASSWORD=CHANGE_ME_GITHUB_TOKEN
DOCKER_IMAGE_NAME=aurigraph
DOCKER_IMAGE_TAG=v2.1.0-prod

# ============================================
# AWS (for AWS deployment)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_KEY
AWS_ACCOUNT_ID=123456789012
AWS_ECS_CLUSTER=aurigraph-production
AWS_ECS_SERVICE=aurigraph-production
AWS_ECR_REPOSITORY=123456789012.dkr.ecr.us-east-1.amazonaws.com/aurigraph

# ============================================
# SSL/TLS
# ============================================
SSL_CERT_PATH=/etc/ssl/certs/aurigraph.crt
SSL_KEY_PATH=/etc/ssl/private/aurigraph.key
SSL_CA_PATH=/etc/ssl/certs/ca-bundle.crt

# ============================================
# GRAFANA
# ============================================
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_ADMIN_PASSWORD
GRAFANA_ADMIN_USER=admin
GRAFANA_ROOT_URL=https://grafana.example.com
GRAFANA_API_KEY=CHANGE_ME_GRAFANA_API_KEY

# ============================================
# SECURITY
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_WINDOW_MS=60000
CSRF_TOKEN_ENABLED=true
HELMET_ENABLED=true
CORS_ENABLED=true

# ============================================
# FEATURES
# ============================================
FEATURE_BACKTESTING=true
FEATURE_OPTIMIZATION=true
FEATURE_MULTI_EXCHANGE=true
FEATURE_STRATEGY_TEMPLATES=true
FEATURE_REAL_TIME_SIGNALS=true

# ============================================
# BACKUP & DISASTER RECOVERY
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 3 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE_PATH=/backups/production
BACKUP_COMPRESSION=gzip

# ============================================
# NOTIFICATIONS
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/CHANGE_ME
SLACK_ENABLED=true
SLACK_CHANNEL=#aurigraph-alerts
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=alerts@example.com
EMAIL_SMTP_PASSWORD=CHANGE_ME_EMAIL_PASSWORD
EMAIL_FROM=aurigraph@example.com

# ============================================
# DEVELOPMENT/DEBUGGING
# ============================================
REQUEST_LOGGING=false
RESPONSE_LOGGING=false
DETAILED_ERROR_MESSAGES=false
PROFILING_ENABLED=false
MEMORY_MONITORING=true

# ============================================
# CUSTOM SETTINGS
# ============================================
# Add any custom environment variables below
CUSTOM_SETTING_1=value
CUSTOM_SETTING_2=value
