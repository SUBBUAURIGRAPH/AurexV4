  "rateLimit": {
    "globalQPS": 500,
    "perExchangeQPS": 100,
    "burstMultiplier": 2.0,
    "backoffStrategy": "exponential",
    "throttleUnder": 0.5
  },
  "connection": {
    "poolSize": 5,
    "maxPoolSize": 50,
    "timeout": 10000,
    "retryAttempts": 3,
    "retryDelay": 1000
  },
  "cache": {
    "enabled": true,
    "backend": "redis",
    "ttl": 300,
    "keys": ["balances", "tradingPairs", "marketData"]
  },
  "monitoring": {
    "healthCheckInterval": 60000,
    "metricsExport": true,
    "metricsPort": 9090,
    "alertOnLatency": 500,
    "alertOnErrorRate": 0.05
  },
  "security": {
    "credentialEncryption": "aes-256-gcm",
    "vault": "local",
    "ipWhitelisting": false,
    "rotationPolicy": "90days",
    "auditLogging": true
  }
}
