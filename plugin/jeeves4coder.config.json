  "codingStandards": {
    "cleanCode": {
      "enabled": true,
      "principles": [
        "Meaningful names",
        "Small functions",
        "Do one thing",
        "Avoid code duplication",
        "Handle errors gracefully"
      ]
    },
    "solid": {
      "enabled": true,
      "principles": [
        "Single Responsibility Principle",
        "Open/Closed Principle",
        "Liskov Substitution Principle",
        "Interface Segregation Principle",
        "Dependency Inversion Principle"
      ]
    },
    "security": {
      "enabled": true,
      "standards": [
        "OWASP Top 10",
        "CWE Top 25",
        "Secure Coding Practices",
        "Input Validation",
        "Authentication & Authorization"
      ]
    },
    "performance": {
      "enabled": true,
      "areas": [
        "Algorithm Optimization",
        "Database Query Optimization",
        "Memory Management",
        "Caching Strategies",
        "Resource Efficiency"
      ]
    }
  },
  "installation": {
    "methods": [
      {
        "name": "npm",
        "command": "npm install @aurigraph/jeeves4coder-plugin",
        "description": "Standard npm package installation"
      },
      {
        "name": "git",
        "command": "git clone https://github.com/Aurigraph-DLT-Corp/glowing-adventure.git && cd glowing-adventure/plugin",
        "description": "Clone from GitHub repository"
      },
      {
        "name": "local",
        "command": "cd plugin && npm install .",
        "description": "Local installation from plugin directory"
      },
      {
        "name": "aurigraph-internal",
        "command": "npm install --registry https://npm.aurigraph.io @aurigraph/jeeves4coder-plugin",
        "description": "Aurigraph internal npm registry (team only)"
      }
    ]
  },
  "configuration": {
    "defaults": {
      "reviewDepth": "standard",
      "outputFormat": "detailed",
      "verbose": false,
      "debug": false
    },
    "reviewDepth": {
      "light": "Quick review focusing on major issues",
      "standard": "Balanced review with issues, suggestions, and metrics",
      "deep": "Comprehensive review including edge cases and advanced analysis"
    },
    "outputFormat": {
      "brief": "Minimal output - key findings only",
      "standard": "Balanced output - main issues and suggestions",
      "detailed": "Complete output - all analysis and recommendations"
    }
  },
  "distribution": {
    "internal": {
      "registry": "https://npm.aurigraph.io",
      "scope": "@aurigraph",
      "access": "restricted",
      "audience": "Aurigraph Team Members"
    },
    "external": {
      "enabled": false,
      "notes": "Currently restricted to Aurigraph team only"
    },
    "support": {
      "email": "agents@aurigraph.io",
      "slack": "#aurigraph-agents",
      "github": "https://github.com/Aurigraph-DLT-Corp/glowing-adventure/issues"
    }
  },
