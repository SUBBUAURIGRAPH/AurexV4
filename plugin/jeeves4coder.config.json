      {"name": "Spring Boot", "expertise": "intermediate"},
      {"name": "NestJS", "expertise": "advanced"},
      {"name": "Ruby on Rails", "expertise": "intermediate"}
    ],
    "cloud": [
      {"name": "AWS", "expertise": "advanced"},
      {"name": "Google Cloud", "expertise": "advanced"},
      {"name": "Azure", "expertise": "advanced"},
      {"name": "DigitalOcean", "expertise": "intermediate"}
    ],
    "devops": [
      {"name": "Docker", "expertise": "advanced"},
      {"name": "Kubernetes", "expertise": "advanced"},
      {"name": "Terraform", "expertise": "advanced"},
      {"name": "CI/CD", "expertise": "advanced"}
    ],
    "databases": [
      {"name": "PostgreSQL", "expertise": "expert"},
      {"name": "MongoDB", "expertise": "expert"},
      {"name": "Redis", "expertise": "advanced"},
      {"name": "MySQL", "expertise": "advanced"},
      {"name": "Elasticsearch", "expertise": "intermediate"}
    ]
  },
  "designPatterns": {
    "creational": [
      "Singleton",
      "Factory",
      "Abstract Factory",
      "Builder",
      "Prototype"
    ],
    "structural": [
      "Adapter",
      "Bridge",
      "Composite",
      "Decorator",
      "Facade",
      "Flyweight",
      "Proxy"
    ],
    "behavioral": [
      "Chain of Responsibility",
      "Command",
      "Iterator",
      "Mediator",
      "Memento",
      "Observer",
      "State",
      "Strategy",
      "Template Method",
      "Visitor",
      "Interpreter"
    ],
    "architectural": [
      "Model-View-Controller (MVC)",
      "Model-View-ViewModel (MVVM)",
      "Model-View-Presenter (MVP)",
      "Redux",
      "Flux",
      "Microservices",
      "Event-Driven Architecture",
      "CQRS",
      "Hexagonal Architecture",
      "Layered Architecture",
