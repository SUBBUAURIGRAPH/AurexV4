{
  "plugin": {
    "name": "Jeeves4Coder",
    "version": "1.0.0",
    "author": "Aurigraph Development Team",
    "type": "claude-code-plugin",
    "description": "Sophisticated coding assistant with refined butler-style service and deep programming expertise",
    "homepage": "https://github.com/Aurigraph-DLT-Corp/glowing-adventure"
  },
  "capabilities": {
    "codeReview": {
      "enabled": true,
      "description": "Comprehensive code review with quality metrics and recommendations",
      "triggerPhrases": [
        "review this code",
        "code review",
        "review for quality",
        "analyze this code",
        "check code quality",
        "code analysis"
      ],
      "outputFormat": ["summary", "issues", "suggestions", "metrics", "recommendations"]
    },
    "refactoring": {
      "enabled": true,
      "description": "Strategic refactoring suggestions for code improvement",
      "triggerPhrases": [
        "refactor this",
        "simplify this code",
        "reduce complexity",
        "modernize this code",
        "improve structure",
        "refactoring help"
      ],
      "outputFormat": ["refactoredCode", "improvements", "explanation", "examples"]
    },
    "architecture": {
      "enabled": true,
      "description": "System architecture review and design pattern recommendations",
      "triggerPhrases": [
        "review architecture",
        "architecture review",
        "how should I design",
        "design pattern",
        "system design",
        "architecture help"
      ],
      "outputFormat": ["recommendations", "patterns", "analysis", "rationale"]
    },
    "performance": {
      "enabled": true,
      "description": "Performance analysis and optimization suggestions",
      "triggerPhrases": [
        "optimize this",
        "performance issue",
        "slow code",
        "performance analysis",
        "optimize performance",
        "benchmarking"
      ],
      "outputFormat": ["optimizations", "benchmarks", "improvements", "examples"]
    },
    "security": {
      "enabled": true,
      "description": "Security vulnerability detection and hardening recommendations",
      "triggerPhrases": [
        "security audit",
        "vulnerability check",
        "secure this code",
        "security review",
        "penetration test",
        "security analysis"
      ],
      "outputFormat": ["vulnerabilities", "fixes", "recommendations", "resources"]
    },
    "testing": {
      "enabled": true,
      "description": "Testing strategy development and test case design",
      "triggerPhrases": [
        "test strategy",
        "how to test",
        "test coverage",
        "testing approach",
        "test design",
        "test recommendations"
      ],
      "outputFormat": ["strategy", "testCases", "coverage", "examples"]
    },
    "documentation": {
      "enabled": true,
      "description": "Code documentation improvement and enhancement",
      "triggerPhrases": [
        "document this",
        "improve documentation",
        "add comments",
        "documentation help",
        "docstring",
        "api documentation"
      ],
      "outputFormat": ["documentation", "examples", "improvements", "standards"]
    }
  },
  "languages": {
    "javascript": {
      "expertise": "expert",
      "version": "ES2020+",
      "tools": ["Node.js", "npm", "yarn", "webpack", "vite"]
    },
    "typescript": {
      "expertise": "expert",
      "version": "5.0+",
      "tools": ["tsc", "ts-node", "jest", "vitest"]
    },
    "python": {
      "expertise": "expert",
      "version": "3.9+",
      "tools": ["pip", "poetry", "pytest", "black", "flake8"]
    },
    "java": {
      "expertise": "intermediate",
      "version": "11+",
      "tools": ["Maven", "Gradle", "JUnit", "Spring Boot"]
    },
    "csharp": {
      "expertise": "intermediate",
      "version": ".NET 6+",
      "tools": [".NET CLI", "NUnit", "xUnit", "Entity Framework"]
    },
    "go": {
      "expertise": "intermediate",
      "version": "1.18+",
      "tools": ["go", "go mod", "testing", "golangci-lint"]
    },
    "rust": {
      "expertise": "intermediate",
      "version": "stable",
      "tools": ["cargo", "rustup", "rustfmt", "clippy"]
    },
    "sql": {
      "expertise": "expert",
      "version": "standard",
      "tools": ["PostgreSQL", "MySQL", "MongoDB", "Redis"]
    },
    "ruby": {
      "expertise": "intermediate",
      "version": "2.7+",
      "tools": ["bundler", "RSpec", "Rails", "Sinatra"]
    },
    "php": {
      "expertise": "intermediate",
      "version": "8.0+",
      "tools": ["Composer", "PHPUnit", "Laravel", "Symfony"]
    }
  },
  "frameworks": {
    "frontend": [
      {"name": "React", "expertise": "expert"},
      {"name": "Vue", "expertise": "advanced"},
      {"name": "Angular", "expertise": "advanced"},
