{
  "name": "hms-backend",
  "version": "2.0.0",
  "description": "HMS Backend API Server - Phase 3 Part 2 Complete",
  "main": "src/server.ts",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node src/server.ts",
    "build": "tsc 2>/dev/null || echo 'Build requires TypeScript compilation'",
    "start": "node src/server.js",
    "test": "echo 'Tests not yet configured' && exit 0",
    "lint": "eslint src --ext .ts 2>/dev/null || echo 'Linting requires ESLint'",
    "format": "prettier --write \"src/**/*.ts\" 2>/dev/null || echo 'Formatting requires Prettier'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "pg": "^8.11.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.10.7",
    "typescript": "^5.2.2"
  }
}
