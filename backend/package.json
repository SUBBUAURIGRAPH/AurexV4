{
  "name": "hms-backend",
  "version": "2.0.0",
  "description": "HMS Backend API Server - Phase 3 Part 2 Complete",
  "main": "src/server.ts",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node src/server.ts",
    "build": "tsc 2>/dev/null || echo 'Build requires TypeScript compilation'",
    "start": "node src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:exchange": "jest --testPathPattern=exchange-connector",
    "test:integration": "jest --testPathPattern=integration",
    "test:performance": "jest --testPathPattern=performance",
    "lint": "eslint src --ext .ts 2>/dev/null || echo 'Linting requires ESLint'",
    "format": "prettier --write \"src/**/*.ts\" 2>/dev/null || echo 'Formatting requires Prettier'"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "http2": "^3.3.6",
    "pg": "^8.11.2",
    "spdy": "^4.0.2"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.10.7",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.2.2"
  }
}
