{
  "dashboard": {
    "title": "Database Performance Dashboard",
    "tags": ["hms", "database", "postgresql"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "title": "Database Connection Pool",
        "type": "graph",
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "pg_stat_database_numbackends{datname=\"hms_production\"}",
            "legendFormat": "Active connections",
            "refId": "A"
          },
          {
            "expr": "pg_settings_max_connections",
            "legendFormat": "Max connections",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "short", "label": "Connections"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [80], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "Database Connection Pool High"
        }
      },
      {
        "id": 2,
        "title": "Query Execution Time (p95)",
        "type": "graph",
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(pg_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p95 query time",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(pg_query_duration_seconds_bucket[5m]))",
            "legendFormat": "p50 query time",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "s", "label": "Query Time"},
          {"format": "short"}
        ],
        "thresholds": [
          {
            "value": 1,
            "colorMode": "critical",
            "op": "gt"
          }
        ]
      },
      {
        "id": 3,
        "title": "Transaction Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "rate(pg_stat_database_xact_commit{datname=\"hms_production\"}[5m])",
            "legendFormat": "Commits/sec",
            "refId": "A"
          },
          {
            "expr": "rate(pg_stat_database_xact_rollback{datname=\"hms_production\"}[5m])",
            "legendFormat": "Rollbacks/sec",
            "refId": "B"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Transactions/sec"},
          {"format": "short"}
        ]
      },
      {
        "id": 4,
        "title": "Top 10 Slowest Queries",
        "type": "table",
        "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "topk(10, pg_stat_statements_mean_exec_time_seconds)",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "query": "Query",
                "Value": "Avg Time (s)"
              }
            }
          }
        ]
      },
      {
        "id": 5,
        "title": "Cache Hit Ratio",
        "type": "gauge",
        "gridPos": {"x": 0, "y": 16, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "(sum(pg_stat_database_blks_hit{datname=\"hms_production\"}) / (sum(pg_stat_database_blks_hit{datname=\"hms_production\"}) + sum(pg_stat_database_blks_read{datname=\"hms_production\"}))) * 100",
            "legendFormat": "Cache hit ratio",
            "refId": "A"
          }
        ],
        "options": {
          "showThresholdLabels": true,
          "showThresholdMarkers": true
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 90, "color": "yellow"},
                {"value": 95, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Database Size",
        "type": "stat",
        "gridPos": {"x": 8, "y": 16, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "pg_database_size_bytes{datname=\"hms_production\"}",
            "legendFormat": "Database size",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "orientation": "auto",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 7,
        "title": "Deadlocks",
        "type": "graph",
        "gridPos": {"x": 16, "y": 16, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "rate(pg_stat_database_deadlocks{datname=\"hms_production\"}[5m])",
            "legendFormat": "Deadlocks/sec",
            "refId": "A"
          }
        ],
        "yaxes": [
          {"format": "ops", "label": "Deadlocks/sec"},
          {"format": "short"}
        ],
        "alert": {
          "conditions": [
            {
              "evaluator": {"params": [0], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"params": [], "type": "avg"},
              "type": "query"
            }
          ],
          "name": "Database Deadlocks Detected"
        }
      },
      {
        "id": 8,
        "title": "Table Sizes",
        "type": "bargauge",
        "gridPos": {"x": 0, "y": 22, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "pg_table_size_bytes",
            "legendFormat": "{{table}}",
            "refId": "A"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes"
          }
        }
      },
      {
        "id": 9,
        "title": "Index Usage",
        "type": "table",
        "gridPos": {"x": 12, "y": 22, "w": 12, "h": 8},
        "targets": [
          {
            "expr": "pg_stat_user_indexes_idx_scan",
            "format": "table",
            "instant": true,
            "refId": "A"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "indexrelname": "Index",
                "relname": "Table",
                "Value": "Scans"
              }
            }
          }
        ]
      }
    ]
  },
  "overwrite": true
}
