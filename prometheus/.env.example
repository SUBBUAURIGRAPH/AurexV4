# HMS Monitoring Stack - Environment Variables
# Copy this file to .env and fill in your values

# ========================================
# ALERTMANAGER CONFIGURATION
# ========================================

# SMTP (Email Notifications)
SMTP_PASSWORD=your-gmail-app-password

# Slack Integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# PagerDuty Integration
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# ========================================
# GRAFANA CONFIGURATION
# ========================================

# Admin credentials
GF_SECURITY_ADMIN_PASSWORD=your-secure-password

# ========================================
# DATABASE CONFIGURATION
# ========================================

# PostgreSQL connection for postgres-exporter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=hms_production
POSTGRES_USER=hms_user
POSTGRES_PASSWORD=your-postgres-password

# ========================================
# REDIS CONFIGURATION (Optional)
# ========================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ========================================
# SETUP INSTRUCTIONS
# ========================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Configure Slack:
#    - Go to https://api.slack.com/apps
#    - Create new app → Incoming Webhooks
#    - Add webhook URL to SLACK_WEBHOOK_URL
#
# 3. Configure Gmail SMTP:
#    - Enable 2FA on Gmail account
#    - Generate App Password: https://myaccount.google.com/apppasswords
#    - Add password to SMTP_PASSWORD
#
# 4. Configure PagerDuty:
#    - Create service in PagerDuty
#    - Add Events API v2 integration
#    - Copy Integration Key to PAGERDUTY_ROUTING_KEY
#
# 5. Set secure Grafana password:
#    - Generate strong password
#    - Add to GF_SECURITY_ADMIN_PASSWORD
#
# 6. Configure database credentials:
#    - Match with your PostgreSQL settings
#
# ========================================
